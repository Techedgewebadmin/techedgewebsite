---
import { featuresCompany } from "@/config/featuresCompany.json";
import { t } from "@/lib/utils";
---

<section class="py-16 md:py-20 px-4 md:px-8 lg:px-12 bg-background text-foreground">
  <div class="max-w-7xl mx-auto flex flex-col items-center text-center space-y-12">
    
    <!-- Main Text Block -->
    <div class="max-w-5xl space-y-6">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-sans font-light leading-tight">
        <span class="font-anton uppercase">{t("company.name")}</span> {t("companyoverview.h2")}
      </h2>
      <h3 class="text-2xl md:text-3xl lg:text-4xl font-sans font-light text-muted leading-tight">
        {t("companyoverview.h3")}
      </h3>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 w-full pt-12 company-features-grid">
      {featuresCompany.map((feature) => (
        <div data-company-card class="bg-white p-6 rounded-2xl flex flex-col gap-4  border-2 border-muted border-dashed">
          <span class="inline-flex items-center justify-center size-10 rounded-lg bg-secondary text-foreground font-mono text-sm">
            {feature.number}
          </span>
          <h4 class="text-xl font-anton uppercase">{feature.title}</h4>
          <p class="text-base text-muted font-grotesk">
            {feature.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll("[data-company-card]");
  gsap.set(cards, { opacity: 0, y: 32 });
  gsap.to(cards, {
    opacity: 1,
    y: 0,
    duration: 0.7,
    ease: "power3.out",
    stagger: 0.12,
    scrollTrigger: {
      trigger: ".company-features-grid",
      start: "top 80%",
      toggleActions: "play none none none",
    },
  });
</script>
