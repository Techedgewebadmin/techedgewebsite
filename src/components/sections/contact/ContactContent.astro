---
import ContactForm from "./ContactForm.astro";
import { socialLinks } from "@/config/socialLinks.json";
import { contactInfo } from "@/config/socialLinks.json";
import { t } from "@/lib/utils";
---

<section class="py-28 md:py-32 px-4 bg-background-foreground">
  <div data-hero-el class="max-w-7xl mx-auto">

    <!-- Page Title -->
    <div class="space-y-4 mb-16">
      <p class="text-sm font-grotesk font-semibold uppercase tracking-widest text-secondary">
        Get In Touch
      </p>
      <h1 class="text-4xl md:text-5xl xl:text-7xl tracking-tight font-anton uppercase leading-none">
        Start Your<br/>Solar Journey
      </h1>
      <p class="text-muted font-sans text-base md:text-lg leading-relaxed max-w-2xl">
        Tell us about your project and we'll get back to you within 24 hours with a free consultation and preliminary quote.
      </p>
    </div>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

      <!-- LEFT: Contact Info -->
      <div class="order-2 lg:order-1 space-y-10 flex flex-col justify-between">
        <div class="space-y-10">

          <!-- Address -->
          <div class="space-y-2 border-b-2 border-dashed border-muted pb-8">
            <p class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
              {t('contact.office')}
            </p>
            <div class="text-foreground font-sans text-lg leading-relaxed">
              <p>{contactInfo.address.street}</p>
              <p>{contactInfo.address.city}</p>
              <p>{contactInfo.address.country}</p>
            </div>
          </div>

          <!-- Email -->
          <div class="space-y-2 border-b-2 border-dashed border-muted pb-8">
            <p class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
              {t('contact.email')}
            </p>
            <a
              href={`mailto:${contactInfo.email}`}
              class="text-2xl md:text-3xl font-anton text-foreground hover:text-secondary transition-colors block"
            >
              {contactInfo.email}
            </a>
          </div>

          <!-- Phone -->
          <div class="space-y-2 border-b-2 border-dashed border-muted pb-8">
            <p class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
              {t('contact.phone')}
            </p>
            <a
              href={`tel:${contactInfo.phone.replace(/\s/g, "")}`}
              class="text-2xl md:text-3xl font-anton text-foreground hover:text-secondary transition-colors block"
            >
              {contactInfo.phone}
            </a>
          </div>

          <!-- Working Hours -->
          <div class="space-y-2 border-b-2 border-dashed border-muted pb-8">
            <p class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
              {t('contact.workingHours')}
            </p>
            <p class="text-foreground font-sans text-lg">{contactInfo.workingHours}</p>
            <p class="text-muted font-sans text-sm">{contactInfo.workingDays}</p>
          </div>

          <!-- What to Expect -->
          <div class="space-y-4">
            <p class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
              What Happens Next
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-4">
                <span class="font-mono text-xs text-secondary font-bold pt-1 shrink-0">01</span>
                <span class="text-foreground font-sans">We review your enquiry within 24 hours</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="font-mono text-xs text-secondary font-bold pt-1 shrink-0">02</span>
                <span class="text-foreground font-sans">Free site assessment scheduled at your convenience</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="font-mono text-xs text-secondary font-bold pt-1 shrink-0">03</span>
                <span class="text-foreground font-sans">Custom proposal & detailed quotation delivered</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="font-mono text-xs text-secondary font-bold pt-1 shrink-0">04</span>
                <span class="text-foreground font-sans">Project kickoff on your timeline</span>
              </li>
            </ul>
          </div>

        </div>

        <!-- Social Links -->
        <div class="pt-8 border-t-2 border-muted border-dashed">
          <p class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted mb-4">
            {t('contact.followUs')}
          </p>
          <div class="flex gap-3 flex-wrap">
            {socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="px-4 py-2 rounded-full border-2 border-muted hover:border-secondary hover:text-secondary text-foreground font-grotesk text-sm font-medium transition-all duration-300"
              >
                {social.label}
              </a>
            ))}
          </div>
        </div>

      </div>

      <!-- RIGHT: Form -->
      <div class="order-1 lg:order-2">
        <div class="bg-white p-8 md:p-10 rounded-2xl border-2 border-muted border-dashed shadow-sm">
          <p class="font-anton text-xl uppercase text-foreground mb-8 tracking-tight">
            Tell Us About Your Project
          </p>
          <ContactForm />
        </div>
      </div>

    </div>
  </div>
</section>
