---
import { Icon } from "@iconify-icon/react";
import ContactForm from "./ContactForm.astro";
import { socialLinks } from "@/config/socialLinks.json";
import { contactInfo } from "@/config/socialLinks.json";
import { t } from "@/lib/utils";
---

<section class="py-16 md:py-24 px-4">
  <div class="max-w-7xl mx-auto">

    <!-- Two-column layout: info left, form right (top-aligned) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- LEFT: Info -->
      <div class="space-y-10">

        <!-- Heading -->
        <div class="space-y-4">
          <h1 class="text-3xl md:text-4xl xl:text-5xl tracking-tight font-anton uppercase leading-none text-foreground">
            Contact Us for a Free Site Survey
          </h1>
          <p class="text-muted-foreground font-sans text-base md:text-lg leading-relaxed">
            Planning to install a solar system or upgrade your existing setup? Our team is here to support you at every step.
          </p>
          <p class="text-muted-foreground font-sans text-base leading-relaxed">
            We offer a complimentary site survey to assess your location, understand your energy requirements, and recommend the most efficient solution tailored to your needs.
          </p>
        </div>

        <!-- Survey points -->
        <div>
          <p class="text-foreground font-sans text-sm font-semibold uppercase tracking-widest mb-4">During the survey, our experts will:</p>
          <ul class="space-y-3 text-muted-foreground font-sans text-base">
            {[
              "Evaluate your rooftop or installation area",
              "Analyze your current electricity consumption",
              "Identify optimal system size and configuration",
              "Check technical feasibility and shading factors",
              "Provide a preliminary savings and ROI estimate",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="text-secondary mt-1 shrink-0">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Solutions -->
        <div>
          <h2 class="text-sm font-grotesk font-semibold uppercase text-muted-foreground mb-4 tracking-widest">Our Solutions</h2>
          <div class="grid grid-cols-2 gap-3">
            {[
              { icon: "☀️", title: "ON-GRID Solar", desc: "Grid-tied, net metering", href: "/solutions/on-grid-solar" },
              { icon: "🏕️", title: "OFF-GRID Solar", desc: "Full energy independence", href: "/solutions/off-grid-solar" },
              { icon: "⚡", title: "Hybrid Solar", desc: "Solar + battery + grid", href: "/solutions/hybrid-solar" },
              { icon: "❄️", title: "Cold Storage Solar", desc: "Built with RINAC", href: "/solutions/hybrid-solar-cold-storage" },
            ].map((sol) => (
              <a href={sol.href}
                class="group bg-foreground/5 border border-muted-foreground/20 hover:border-secondary rounded-xl p-4 flex flex-col gap-2 transition-all duration-200">
                <span class="text-2xl">{sol.icon}</span>
                <div class="font-anton uppercase text-sm tracking-wide text-foreground leading-tight">{sol.title}</div>
                <div class="text-xs text-muted-foreground font-grotesk">{sol.desc}</div>
                <div class="text-xs text-secondary font-semibold mt-auto flex items-center gap-0.5 group-hover:gap-1 transition-all">Learn more →</div>
              </a>
            ))}
          </div>
        </div>

        <!-- Contact Details -->
        <div class="space-y-6 pt-4 border-t border-muted-foreground/20">
          <div class="space-y-1">
            <h3 class="text-xs font-grotesk font-semibold uppercase text-muted-foreground tracking-widest">{t('contact.office')}</h3>
            <div class="text-foreground font-sans text-sm">
              <p>{contactInfo.address.street}</p>
              <p>{contactInfo.address.city}</p>
              <p>{contactInfo.address.country}</p>
            </div>
          </div>
          <div class="space-y-1">
            <h3 class="text-xs font-grotesk font-semibold uppercase text-muted-foreground tracking-widest">{t('contact.email')}</h3>
            <a href={`mailto:${contactInfo.email}`} class="text-xl font-anton text-foreground hover:text-secondary transition-colors block">
              {contactInfo.email}
            </a>
          </div>
          <div class="space-y-1">
            <h3 class="text-xs font-grotesk font-semibold uppercase text-muted-foreground tracking-widest">{t('contact.phone')}</h3>
            <a href={`tel:${contactInfo.phone.replace(/\s/g, "")}`} class="text-xl font-anton text-foreground hover:text-secondary transition-colors block">
              {contactInfo.phone}
            </a>
          </div>
        </div>

      </div>

      <!-- RIGHT: Form (sticky top) -->
      <div class="lg:sticky lg:top-28 bg-white p-8 md:p-10 rounded-2xl shadow-sm border border-muted-foreground/20">
        <ContactForm />
      </div>

    </div>
  </div>
</section>
