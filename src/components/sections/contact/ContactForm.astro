---
import Button from "@/components/ui/buttons/Button.astro";
---

<form class="space-y-6" id="contact-form" novalidate>

  <!-- Status Message -->
  <div id="form-message" class="hidden"></div>

  <!-- Honeypot (spam protection) -->
  <input
    type="text"
    name="company_bot"
    style="position:absolute;left:-9999px;width:1px;height:1px;"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <!-- Row 1: Name + Phone -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="space-y-2">
      <label for="name" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
        Full Name *
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Rajesh Kumar"
        class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 placeholder:text-muted/40 font-sans"
      />
      <p class="text-red-500 text-xs hidden" data-error="name"></p>
    </div>

    <div class="space-y-2">
      <label for="phone" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
        Phone Number *
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        placeholder="+91 98765 43210"
        class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 placeholder:text-muted/40 font-sans"
      />
      <p class="text-red-500 text-xs hidden" data-error="phone"></p>
    </div>
  </div>

  <!-- Row 2: Email + Company -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="space-y-2">
      <label for="email" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
        Email Address *
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="rajesh@company.com"
        class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 placeholder:text-muted/40 font-sans"
      />
      <p class="text-red-500 text-xs hidden" data-error="email"></p>
    </div>

    <div class="space-y-2">
      <label for="company" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
        Company Name
      </label>
      <input
        type="text"
        id="company"
        name="company"
        placeholder="Your Company Pvt. Ltd."
        class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 placeholder:text-muted/40 font-sans"
      />
    </div>
  </div>

  <!-- Row 3: City + System Type -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="space-y-2">
      <label for="city" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
        City / Location *
      </label>
      <input
        type="text"
        id="city"
        name="city"
        required
        placeholder="Bangalore, Karnataka"
        class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 placeholder:text-muted/40 font-sans"
      />
      <p class="text-red-500 text-xs hidden" data-error="city"></p>
    </div>

    <div class="space-y-2">
      <label for="system_type" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
        System Type *
      </label>
      <select
        id="system_type"
        name="system_type"
        required
        class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 font-sans text-foreground appearance-none cursor-pointer"
      >
        <option value="" disabled selected>Select system type</option>
        <option value="Residential Rooftop">Residential Rooftop</option>
        <option value="Commercial Rooftop">Commercial Rooftop</option>
        <option value="Industrial Rooftop">Industrial Rooftop</option>
        <option value="Ground Mount">Ground Mount / Utility Scale</option>
        <option value="Hybrid">Hybrid System</option>
        <option value="Offgrid">Off-Grid System</option>
        <option value="Not Sure">Not Sure — Need Guidance</option>
      </select>
      <p class="text-red-500 text-xs hidden" data-error="system_type"></p>
    </div>
  </div>

  <!-- Row 4: Capacity -->
  <div class="space-y-2">
    <label for="capacity" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
      Approximate Capacity Required (kW)
    </label>
    <div class="flex items-center gap-3">
      <input
        type="number"
        id="capacity"
        name="capacity"
        min="1"
        placeholder="e.g. 50"
        class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 placeholder:text-muted/40 font-sans"
      />
      <span class="text-muted font-grotesk text-sm shrink-0">kW</span>
    </div>
    <p class="text-muted font-sans text-xs mt-1">Not sure? Leave blank — we'll help you size it.</p>
  </div>

  <!-- Row 5: Message -->
  <div class="space-y-2">
    <label for="message" class="text-xs font-grotesk font-semibold uppercase tracking-widest text-muted">
      Project Details / Message
    </label>
    <textarea
      id="message"
      name="message"
      rows="4"
      placeholder="Tell us about your project — roof type, current electricity bill, any specific requirements..."
      class="w-full px-4 py-3 bg-transparent border-b-2 border-muted focus:border-secondary outline-none transition-colors duration-300 placeholder:text-muted/40 resize-none font-sans"
    ></textarea>
  </div>

  <!-- Submit -->
  <div class="pt-2">
    <Button variant="solid" size="md" class="w-full md:w-auto px-12" id="submit-btn" type="button">
      <span id="btn-text">Send Enquiry →</span>
      <span id="btn-loader" class="hidden">
        <svg class="animate-spin h-4 w-4 inline-block mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Sending...
      </span>
    </Button>
    <p class="text-muted font-sans text-xs mt-3">
      We typically respond within 24 hours on business days.
    </p>
  </div>

</form>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText    = document.getElementById('btn-text');
  const btnLoader  = document.getElementById('btn-loader');
  const formMsg    = document.getElementById('form-message');

  function showMessage(type: 'success' | 'error', text: string) {
    if (!formMsg) return;
    formMsg.classList.remove('hidden');
    formMsg.className = type === 'success'
      ? 'p-4 bg-green-50 border-2 border-green-400 rounded-xl text-green-800 font-sans text-sm'
      : 'p-4 bg-red-50 border-2 border-red-400 rounded-xl text-red-800 font-sans text-sm';
    formMsg.innerHTML = `<p class="font-semibold">${text}</p>`;
    formMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function setLoading(loading: boolean) {
    if (!submitBtn || !btnText || !btnLoader) return;
    submitBtn.disabled = loading;
    btnText.classList.toggle('hidden', loading);
    btnLoader.classList.toggle('hidden', !loading);
  }

  function validateForm(): boolean {
    let valid = true;
    const required = ['name', 'phone', 'email', 'city', 'system_type'];

    // Clear all errors
    document.querySelectorAll('[data-error]').forEach(el => {
      el.classList.add('hidden');
      el.textContent = '';
    });

    required.forEach(field => {
      const input = form.querySelector(`[name="${field}"]`) as HTMLInputElement | HTMLSelectElement;
      const errorEl = form.querySelector(`[data-error="${field}"]`);
      if (!input || !errorEl) return;

      if (!input.value.trim()) {
        errorEl.classList.remove('hidden');
        errorEl.textContent = 'This field is required.';
        valid = false;
      }
    });

    // Email format check
    const emailInput = form.querySelector('[name="email"]') as HTMLInputElement;
    const emailError = form.querySelector('[data-error="email"]');
    if (emailInput?.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
      if (emailError) {
        emailError.classList.remove('hidden');
        emailError.textContent = 'Please enter a valid email address.';
      }
      valid = false;
    }

    // Phone check (min 7 digits)
    const phoneInput = form.querySelector('[name="phone"]') as HTMLInputElement;
    const phoneError = form.querySelector('[data-error="phone"]');
    if (phoneInput?.value && phoneInput.value.replace(/\D/g, '').length < 7) {
      if (phoneError) {
        phoneError.classList.remove('hidden');
        phoneError.textContent = 'Please enter a valid phone number.';
      }
      valid = false;
    }

    return valid;
  }

  if (submitBtn) {
    submitBtn.addEventListener('click', async () => {
      if (!formMsg) return;
      formMsg.classList.add('hidden');

      if (!validateForm()) return;

      // Honeypot check
      const botField = form.querySelector('[name="company_bot"]') as HTMLInputElement;
      if (botField?.value) return; // silently reject bots

      setLoading(true);

      try {
        // Collect form data
        const data = {
          name:        (form.querySelector('[name="name"]') as HTMLInputElement).value.trim(),
          phone:       (form.querySelector('[name="phone"]') as HTMLInputElement).value.trim(),
          email:       (form.querySelector('[name="email"]') as HTMLInputElement).value.trim(),
          company:     (form.querySelector('[name="company"]') as HTMLInputElement).value.trim(),
          city:        (form.querySelector('[name="city"]') as HTMLInputElement).value.trim(),
          system_type: (form.querySelector('[name="system_type"]') as HTMLSelectElement).value,
          capacity:    (form.querySelector('[name="capacity"]') as HTMLInputElement).value.trim(),
          message:     (form.querySelector('[name="message"]') as HTMLTextAreaElement).value.trim(),
          submitted_at: new Date().toISOString(),
        };

        // ─── INTEGRATION POINT ───────────────────────────────────────
        // When your Supabase is ready, replace this block with:
        //
        // const { error } = await supabase.from('enquiries').insert([data]);
        // if (error) throw error;
        //
        // For now — simulate a successful submission
        await new Promise(resolve => setTimeout(resolve, 1200));
        console.log('Enquiry data (ready for Supabase):', data);
        // ─────────────────────────────────────────────────────────────

        showMessage('success', '✓ Thank you! We\'ve received your enquiry and will contact you within 24 hours.');
        form.reset();

      } catch (err) {
        console.error('Submission error:', err);
        showMessage('error', '✗ Something went wrong. Please call us directly or try again.');
      } finally {
        setLoading(false);
      }
    });
  }
</script>
