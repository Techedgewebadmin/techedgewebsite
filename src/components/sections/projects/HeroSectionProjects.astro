---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import Button from "@/components/ui/buttons/Button.astro";
import { t } from "@/lib/utils";

interface Props {
  projects?: CollectionEntry<"projects">[];
}

const { projects = [] } = Astro.props;

// Real company totals (200+ projects across India, 2+ MW installed)
// CO2: 2,000 kWp × 4.5 sun hrs × 365 × 0.82 kg/kWh ÷ 1000 ≈ 1,680 t/year (conservative)
const totalProjects = "200+";
const totalMW = "2+ MW";
const totalCO2 = "1,700+";
---

<section class="fixed top-0 left-0 w-full h-dvh overflow-hidden z-0">
  <video
    class="absolute inset-0 w-full h-full object-cover pointer-events-none"
    muted
    autoplay
    loop
    playsinline
    transition:persist
  >
    <source src="/videos/video4.mp4" type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-black opacity-30 pointer-events-none"></div>

  <div
    class="relative z-10 h-full flex flex-col lg:flex-row items-start lg:items-baseline-last justify-end lg:justify-between p-4 lg:p-12 gap-6 lg:gap-0"
  >
    <div class="max-w-3xl space-y-4 text-accent-foreground">

      <!-- Slide 1: Identity -->
      <div class="proj-slide" data-slide="0">
        <h1 data-hero-el class="text-4xl lg:text-6xl xl:text-8xl font-anton uppercase leading-none">
          Real Results.<br/>Real Impact.
        </h1>
        <p data-hero-el class="text-base lg:text-lg xl:text-xl mt-4 max-w-xl font-sans">
          {t('project.page.hero.description')}
        </p>
        <Button
          data-hero-el
          href="/contact"
          variant="secondary"
          class="font-anton text-base lg:text-xl uppercase max-w-sm mt-4"
          size="lg"
        >
          {t("project.page.hero.btn")}
        </Button>
      </div>

      <!-- Slide 2: Scale -->
      <div class="proj-slide hidden" data-slide="1">
        <p class="text-sm font-bold uppercase tracking-widest text-secondary mb-3">Our Portfolio</p>
        <h1 class="text-4xl lg:text-6xl xl:text-8xl font-anton uppercase leading-none">
          Industrial.<br/>Residential.<br/>Agricultural.
        </h1>
        <p class="text-base lg:text-lg xl:text-xl mt-4 max-w-xl font-sans">
          From 1 MW factory rooftops to rural goshalas — solar designed and installed for every scale and sector across India.
        </p>
        <Button
          href="/projects"
          variant="secondary"
          class="font-anton text-base lg:text-xl uppercase max-w-sm mt-4"
          size="lg"
        >
          View All Projects
        </Button>
      </div>

      <!-- Slide 3: Impact -->
      <div class="proj-slide hidden" data-slide="2">
        <p class="text-sm font-bold uppercase tracking-widest text-secondary mb-3">Environmental Impact</p>
        <h1 class="text-4xl lg:text-6xl xl:text-8xl font-anton uppercase leading-none">
          1,700+<br/>Tonnes CO₂<br/>Saved.
        </h1>
        <p class="text-base lg:text-lg xl:text-xl mt-4 max-w-xl font-sans">
          Every system installed is working 365 days a year — generating clean power, cutting bills, and reducing emissions for 25 years.
        </p>
        <Button
          href="/contact"
          variant="secondary"
          class="font-anton text-base lg:text-xl uppercase max-w-sm mt-4"
          size="lg"
        >
          Start Your Project
        </Button>
      </div>

      <!-- Dot nav -->
      <div class="flex items-center gap-2 pt-2" data-hero-el>
        <button class="proj-dot rounded-full transition-all duration-300" data-target="0" style="width:20px;height:4px;background:#86efac" aria-label="Slide 1"></button>
        <button class="proj-dot rounded-full transition-all duration-300" data-target="1" style="width:8px;height:4px;background:rgba(255,255,255,0.3)" aria-label="Slide 2"></button>
        <button class="proj-dot rounded-full transition-all duration-300" data-target="2" style="width:8px;height:4px;background:rgba(255,255,255,0.3)" aria-label="Slide 3"></button>
      </div>
    </div>

    <!-- Cards adaptadas a mobile -->
    <div
      data-hero-el
      class="grid grid-cols-3 lg:grid-cols-1 xl:grid-cols-3 gap-2 lg:gap-4 w-full lg:w-auto"
    >
      <!-- Projects Done -->
      <div
        class="bg-background-foreground rounded-lg p-3 lg:p-4 flex flex-col justify-between min-h-[100px] lg:min-h-[120px]"
      >
        <p
          class="text-2xl lg:text-4xl font-grotesk font-semibold text-foreground"
        >
          {totalProjects}
        </p>
        <div class="flex items-center justify-between mt-2">
          <p
            class="text-muted text-xs lg:text-base uppercase font-semibold font-grotesk"
          >
            Projects
          </p>
          <Icon
            name="arrow"
            size={20}
            class="text-secondary -rotate-45 lg:w-7 lg:h-7"
          />
        </div>
      </div>

      <!-- Total MW Installed -->
      <div
        class="bg-background-foreground rounded-lg p-3 lg:p-4 flex flex-col justify-between min-h-[100px] lg:min-h-[120px]"
      >
        <p
          class="text-2xl lg:text-4xl font-grotesk font-semibold text-foreground"
        >
          {totalMW}
        </p>
        <div class="flex items-start justify-between mt-2">
          <p
            class="text-foreground text-xs lg:text-base uppercase font-semibold font-grotesk"
          >
            Installed
          </p>
          <Icon
            name="arrow"
            size={20}
            class="text-secondary -rotate-45 lg:w-7 lg:h-7"
          />
        </div>
      </div>

      <!-- CO2 Saved -->
      <div
        class="bg-secondary rounded-md p-3 lg:p-4 flex flex-col justify-between min-h-[100px] lg:min-h-[120px]"
      >
        <p
          class="text-xl lg:text-4xl font-grotesk font-semibold text-foreground"
        >
          {totalCO2}t
        </p>
        <div class="flex items-start justify-between mt-2">
          <p
            class="text-foreground text-xs lg:text-base uppercase font-grotesk font-semibold"
          >
            CO2 Saved
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Spacer so that the content starts after the hero -->
<div class="h-dvh"></div>

<script>
  const slides   = document.querySelectorAll('.proj-slide');
  const dots     = document.querySelectorAll('.proj-dot');
  const DURATION = 5500;
  let current = 0;
  let timer: ReturnType<typeof setTimeout>;

  function goTo(idx: number) {
    // Fade out current slide
    const outEl = slides[current] as HTMLElement;
    outEl.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
    outEl.style.opacity = '0';
    outEl.style.transform = 'translateY(-12px)';

    setTimeout(() => {
      outEl.classList.add('hidden');
      outEl.style.opacity = '';
      outEl.style.transform = '';
      outEl.style.transition = '';
      current = idx;

      const inEl = slides[current] as HTMLElement;
      inEl.classList.remove('hidden');
      inEl.style.opacity = '0';
      inEl.style.transform = 'translateY(12px)';
      inEl.style.transition = '';

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          inEl.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          inEl.style.opacity = '1';
          inEl.style.transform = 'translateY(0)';
        });
      });
    }, 370);

    // Update dots
    dots.forEach((d, i) => {
      const el = d as HTMLElement;
      if (i === idx) {
        el.style.width = '20px';
        el.style.background = '#86efac';
      } else {
        el.style.width = '8px';
        el.style.background = 'rgba(255,255,255,0.3)';
      }
    });
  }

  function next() {
    goTo((current + 1) % slides.length);
    clearTimeout(timer);
    timer = setTimeout(next, DURATION);
  }

  // Boot
  timer = setTimeout(next, DURATION);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearTimeout(timer);
      goTo(i);
      timer = setTimeout(next, DURATION);
    });
  });
</script>

