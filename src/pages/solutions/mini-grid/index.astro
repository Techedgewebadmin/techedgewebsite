              <div class="flex justify-between border-b border-muted/10 pb-2">
                <span class="text-muted">Night backup (214.5 kWh)</span>
                <span class="font-bold text-foreground">~8–10 hrs</span>
              </div>
              <div class="flex justify-between">
                <span class="text-muted">Surplus / export</span>
                <span class="font-bold text-foreground">~255 kWh</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mid-page CTA -->
      <div class="bg-secondary/5 border border-secondary/20 rounded-2xl p-8 text-center">
        <h3 class="font-anton text-2xl uppercase text-foreground mb-2">Get a System Sized for Your Village</h3>
        <p class="text-muted text-sm mb-6">Share community details — we'll design the system and send a full project report within 3 working days.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact" class="bg-secondary text-black font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-secondary/90 transition-colors">
            Request Project Report
          </a>
          <a href="https://wa.me/919844097096?text=Hi%2C%20I%20need%20a%20solar%20mini%20grid%20project%20assessment%20for%20my%20village%2FNGO%20program." target="_blank" rel="noopener noreferrer" class="bg-green-600 text-white font-bold text-sm uppercase px-8 py-4 rounded-xl hover:bg-green-700 transition-colors text-center tracking-widest">
            💬 WhatsApp Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- BUDGET TABLE -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="py-16 px-4 bg-muted-foreground/3 border-b border-muted/10">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <span class="text-secondary text-xs font-bold uppercase tracking-widest">Budget Guide</span>
        <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mt-2">Approximate Project Budget</h2>
        <p class="text-muted text-sm mt-2">Indicative estimates for 150 kWp / 214.5 kWh system. Actual costs depend on site, terrain and scope.</p>
      </div>

      <!-- Core infrastructure table -->
      <div class="overflow-x-auto mb-6">
        <table class="w-full text-sm border border-muted/20 rounded-2xl overflow-hidden">
          <thead>
            <tr class="bg-muted-foreground/10">
