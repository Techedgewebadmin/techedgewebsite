  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- NGO / CSR FUNDING MODEL -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-secondary text-xs font-bold uppercase tracking-widest">Funding</span>
        <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mt-2">NGO & CSR Funding Model</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-10 items-start">
        <!-- Funding structure -->
        <div>
          <h3 class="font-bold text-foreground mb-4">Typical Funding Mix</h3>
