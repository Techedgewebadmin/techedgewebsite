              <th class="px-5 py-3 text-right font-bold text-secondary">Approx. Budget (₹)</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['150 kWp Solar PV Modules (Goldi TOPCon)', '27 – 32 Lakhs'],
