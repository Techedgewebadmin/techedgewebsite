            {[
              { source: 'NGO / CSR Grant', pct: '40–70%', color: 'bg-secondary/20 border-secondary/40' },
              { source: 'Climate Finance (GCF, GEF, World Bank)', pct: '20–40%', color: 'bg-blue-500/20 border-blue-500/40' },
              { source: 'Community Participation', pct: '5–10%', color: 'bg-green-500/20 border-green-500/40' },
              { source: 'Revenue from Tariffs (operational)', pct: 'Ongoing', color: 'bg-orange-500/20 border-orange-500/40' },
            ].map(f => (
              <div class={`flex items-center justify-between rounded-xl px-4 py-3 border ${f.color}`}>
