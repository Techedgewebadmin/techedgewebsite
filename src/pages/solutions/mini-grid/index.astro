                <td class="px-5 py-3 text-right font-bold text-foreground">₹ {budget}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="border-t-2 border-secondary/30 bg-secondary/5">
              <td class="px-5 py-4 font-bold text-foreground">Total — Core System (excl. distribution)</td>
              <td class="px-5 py-4 text-right font-anton text-xl text-secondary">₹ 83 – 105 Lakhs</td>
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- Distribution add-on -->
      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-6">
          <h3 class="font-bold text-foreground mb-3">+ Village Distribution Network</h3>
          <p class="text-muted text-sm mb-3">Poles, LT lines, service connections, metering per household.</p>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between border-b border-muted/10 pb-2">
              <span class="text-muted">Distribution infrastructure</span>
              <span class="font-bold text-foreground">₹10 – 20 Lakhs</span>
