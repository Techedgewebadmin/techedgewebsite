      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-10">
        <!-- Community -->
        <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-6">
          <h3 class="font-bold text-foreground mb-4 flex items-center gap-2"><span class="text-2xl">🏘️</span> Community Infrastructure</h3>
          <div class="space-y-2">
            {[
              ['Homes', '50'],
              ['Shops / Stalls', '10'],
              ['School', '1'],
              ['Healthcare Centre', '1'],
              ['Water Pumps', '2'],
              ['Telecom Tower', '1'],
              ['Cold Storage Unit', '1'],
