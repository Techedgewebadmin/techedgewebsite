          <h3 class="font-bold text-foreground mb-4">Example Consumer Tariffs</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border border-muted/20 rounded-2xl overflow-hidden">
              <thead>
                <tr class="bg-muted-foreground/10">
                  <th class="px-4 py-2 text-left text-xs text-muted uppercase font-semibold">Consumer Type</th>
                  <th class="px-4 py-2 text-right text-xs text-muted uppercase font-semibold">Tariff (₹/unit)</th>
                </tr>
              </thead>
              <tbody>
