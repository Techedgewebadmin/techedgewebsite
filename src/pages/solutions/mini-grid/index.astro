          <div class="space-y-2">
            {[
              ['Residential Homes', '200 kWh'],
              ['Shops', '40 kWh'],
              ['School', '15 kWh'],
              ['Clinic', '20 kWh'],
              ['Water Pumps', '50 kWh'],
              ['Telecom Tower', '15 kWh'],
