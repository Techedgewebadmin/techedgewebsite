---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Solar Mini Grid Solutions — Village Electrification India & Africa | Techedge"
  description="Solar mini grid systems for rural villages, NGOs, CSR programs and remote communities across India and Africa. 150kWp solar + 214.5kWh LiFePO₄ battery + 100kW PCS. Full EPC, commissioning and project documentation. Contact Techedge for a free assessment."
  keywords="solar mini grid India, village electrification solar, NGO solar project India, CSR solar rural electrification, solar mini grid Africa, off-grid village power, rural solar microgrid, solar BESS village, community solar project, remote electrification India, solar mini grid NGO, mini grid Africa Kenya Tanzania Nigeria"
>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- HERO -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="bg-background-foreground pt-32 pb-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <nav class="flex items-center gap-2 text-xs text-muted font-semibold mb-6">
          <a href="/" class="hover:text-secondary transition-colors">Home</a>
          <span>/</span>
          <a href="/solutions/" class="hover:text-secondary transition-colors">Solutions</a>
          <span>/</span>
          <span class="text-foreground">Solar Mini Grid</span>
        </nav>
        <span class="text-secondary text-xs font-bold uppercase tracking-widest mb-3 block">🌍 NGO · CSR · Rural Electrification</span>
        <h1 class="font-anton text-4xl md:text-6xl xl:text-7xl uppercase text-foreground leading-none mb-4">
          Solar<br />
          <span class="text-secondary">Mini Grid</span><br />
          Solutions
        </h1>
        <p class="text-muted text-lg leading-relaxed mb-4">
          Power entire villages — homes, schools, clinics, water pumps — with a complete
          solar mini grid. 150 kWp solar + 214.5 kWh LiFePO₄ BESS + 100 kW PCS.
          No diesel. No grid required. Full EPC by Techedge India.
        </p>
        <p class="text-muted text-sm mb-8">
          Deployed for NGOs, CSR programs, Rotary Clubs, climate funds and government agencies across
          <strong class="text-foreground">India and Africa</strong>.
        </p>

        <!-- Lead CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 mb-6">
          <a href="/contact" class="bg-secondary text-black font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-secondary/90 transition-colors text-center">
            Free Project Assessment
          </a>
          <a href="tel:+919844097096" class="bg-muted-foreground/10 border border-muted/30 text-foreground font-bold text-sm uppercase px-8 py-4 rounded-xl hover:bg-muted-foreground/20 transition-colors text-center tracking-widest">
            📞 (+91) 98440 97096
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {['✅ Full EPC turnkey', '✅ CSR documentation', '✅ Impact reports', '✅ Pan-India & Africa'].map(t => (
            <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-secondary/10 border border-secondary/20 text-secondary">{t}</span>
          ))}
        </div>
      </div>

      <!-- Stats panel -->
      <div class="grid grid-cols-2 gap-4">
        {[
          { icon: '⚡', v: '150 kWp', l: 'Solar PV Capacity' },
          { icon: '🔋', v: '214.5 kWh', l: 'LiFePO₄ BESS' },
          { icon: '🔌', v: '100 kW', l: 'AC Output (PCS)' },
          { icon: '🏘️', v: '50–200', l: 'Households / System' },
          { icon: '🌞', v: '675 kWh', l: 'Daily Generation' },
          { icon: '📈', v: '10+ yrs', l: 'Battery Warranty' },
          { icon: '🌍', v: 'India + Africa', l: 'Deployment Regions' },
          { icon: '💰', v: '₹75L – 1.4Cr', l: 'Indicative Budget' },
        ].map(s => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-4 text-center">
            <p class="text-2xl mb-1">{s.icon}</p>
            <p class="font-grotesk font-bold text-foreground text-lg">{s.v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{s.l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- WHAT IS A SOLAR MINI GRID -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-start">
      <div>
        <span class="text-secondary text-xs font-bold uppercase tracking-widest mb-3 block">Overview</span>
        <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mb-6">What Is a Solar Mini Grid?</h2>
        <p class="text-muted leading-relaxed mb-4">
          A <strong class="text-foreground">Solar Mini Grid</strong> is a localised electricity generation and distribution system that powers
          an entire community — independently of the national grid. Using solar panels, battery storage,
          and smart power management, it delivers reliable 24/7 electricity to homes, schools, clinics,
          water systems, and productive loads.
        </p>
        <p class="text-muted leading-relaxed mb-4">
          Unlike rooftop solar (which serves a single building), a mini grid builds a
          <strong class="text-foreground">shared AC distribution network</strong> — typically 415V 3-phase backbone
          with 230V single-phase household supply — serving dozens or hundreds of end consumers.
        </p>
        <p class="text-muted leading-relaxed">
          Generator or grid backup can be integrated via an Automatic Transfer Switch (STS)
          for uninterrupted supply during extended cloudy periods.
        </p>
      </div>
      <div class="space-y-3">
        <h3 class="font-bold text-foreground text-sm uppercase tracking-wide mb-4">Mini Grid Powers All Of This</h3>
        {[
          ['🏠', 'Residential Homes', 'Lighting, fans, charging, appliances'],
          ['🏫', 'Schools & Colleges', 'Lighting, computers, projectors'],
          ['🏥', 'Health Clinics', 'Medical equipment, refrigeration, lighting'],
          ['💧', 'Water Pumps', 'Drinking water, irrigation'],
          ['📡', 'Telecom Towers', '24/7 connectivity infrastructure'],
          ['🧊', 'Cold Storage', 'Perishables, vaccines, food preservation'],
          ['🔨', 'Productive Loads', 'Grain mills, workshops, EV charging'],
          ['🛒', 'Shops & Commerce', 'Commercial loads, POS, refrigeration'],
        ].map(([icon, title, desc]) => (
          <div class="flex items-start gap-3 bg-muted-foreground/5 rounded-xl px-4 py-3 border border-muted/10">
            <span class="text-xl flex-shrink-0">{icon}</span>
            <div>
              <p class="font-semibold text-foreground text-sm">{title}</p>
              <p class="text-muted text-xs">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- SYSTEM ARCHITECTURE -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="py-16 px-4 bg-muted-foreground/3 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-secondary text-xs font-bold uppercase tracking-widest">System Design</span>
        <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mt-2">Recommended Village System</h2>
        <p class="text-muted text-sm mt-2 max-w-xl mx-auto">Deye commercial-grade components. No compromise on reliability.</p>
      </div>

      <!-- Architecture diagram -->
      <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-6 md:p-10 mb-10 text-center font-mono text-sm">
        <div class="flex flex-wrap justify-center items-center gap-2 text-foreground">
          <span class="bg-yellow-500/20 border border-yellow-500/30 rounded-xl px-4 py-2 font-bold">☀️ Solar PV<br/><span class="text-xs font-sans text-muted">100–150 kWp</span></span>
          <span class="text-muted text-xl">→</span>
          <span class="bg-secondary/20 border border-secondary/30 rounded-xl px-4 py-2 font-bold">📡 MPPT<br/><span class="text-xs font-sans text-muted">200kWp, 8-tracker</span></span>
          <span class="text-muted text-xl">→</span>
          <span class="bg-blue-500/20 border border-blue-500/30 rounded-xl px-4 py-2 font-bold">⚙️ PCS<br/><span class="text-xs font-sans text-muted">100kW bidirectional</span></span>
          <span class="text-muted text-xl">↔</span>
          <span class="bg-orange-500/20 border border-orange-500/30 rounded-xl px-4 py-2 font-bold">🔋 BOS-B BESS<br/><span class="text-xs font-sans text-muted">214.5 kWh LiFePO₄</span></span>
        </div>
        <div class="flex justify-center mt-3 mb-3 text-muted text-xl">↓</div>
        <div class="flex flex-wrap justify-center items-center gap-2">
          <span class="bg-purple-500/20 border border-purple-500/30 rounded-xl px-4 py-2 font-bold text-foreground">🔀 STS<br/><span class="text-xs font-sans text-muted">500kW, &lt;20ms switch</span></span>
          <span class="text-muted text-xl">→</span>
          <span class="bg-green-500/20 border border-green-500/30 rounded-xl px-4 py-2 font-bold text-foreground">🌐 AC Mini Grid<br/><span class="text-xs font-sans text-muted">415V 3-phase distribution</span></span>
        </div>
        <div class="flex justify-center mt-3 text-muted text-xl">↓</div>
        <div class="flex flex-wrap justify-center gap-2 mt-2 text-xs text-foreground">
          {['🏠 Homes (230V)', '🏫 Schools', '🏥 Clinics', '💧 Pumps', '📡 Telecom', '🧊 Cold Storage'].map(t => (
            <span class="bg-muted-foreground/10 border border-muted/20 rounded-full px-3 py-1">{t}</span>
          ))}
        </div>
        <p class="text-xs text-muted mt-4">Grid / DG backup via STS auto-switching</p>
      </div>

      <!-- Spec table -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-muted/20 rounded-2xl overflow-hidden">
          <thead>
            <tr class="bg-muted-foreground/10">
              <th class="px-5 py-3 text-left text-xs text-muted uppercase font-semibold tracking-widest">Component</th>
              <th class="px-5 py-3 text-left font-bold text-secondary">Specification</th>
              <th class="px-5 py-3 text-left text-xs text-muted uppercase font-semibold tracking-widest">Product</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Solar PV Capacity', '100–150 kWp (expandable)', 'Goldi Solar TOPCon Bifacial'],
              ['Battery Storage', '214.5 kWh LiFePO₄ (scalable to 429 kWh)', 'Deye BOS-B ESS'],
              ['PCS Hybrid Inverter', '100 kW, 98.5% efficiency, bidirectional', 'Deye SUN-100K-PCS01HP3'],
              ['MPPT Solar Controller', '200 kWp, 8 independent trackers', 'Deye MPPT Module'],
              ['STS Transfer System', '500 kW, <20ms switching', 'Deye STS Module'],
              ['Battery Cycle Life', '≥6,000 cycles @ 80% DoD', 'Deye BOS-B (10-yr warranty)'],
              ['Distribution Voltage', '415V 3-Phase backbone', 'LT panel design by Techedge'],
              ['Household Supply', '230V Single Phase', 'Per IEC/IS standards'],
            ].map(([comp, spec, prod]) => (
              <tr class="border-t border-muted/10 hover:bg-muted-foreground/3">
                <td class="px-5 py-3 font-semibold text-foreground text-sm">{comp}</td>
                <td class="px-5 py-3 text-foreground">{spec}</td>
                <td class="px-5 py-3 text-muted text-xs">{prod}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- EXAMPLE VILLAGE PROJECT -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="py-16 px-4 border-b border-muted/10">
