---
import Layout from "@/layouts/Layout.astro";
import Heading from "@/components/common/Heading.astro";
import Cta from "@/components/common/Cta.astro";
import { solutions } from "@/data/solutions";
---

<Layout
  title="Techedge | Solar Solutions"
  description="Explore our complete range of solar solutions — On-Grid, Off-Grid, Hybrid, and Hybrid Cold Storage systems designed for homes, businesses, and cold chain operations."
  keywords="on-grid solar, off-grid solar, hybrid solar, solar cold storage, solar EPC Bangalore"
>
  <!-- Hero -->
  <section class="bg-foreground text-primary pt-32 md:pt-40 pb-16 md:pb-24">
    <div class="container mx-auto px-4 max-w-7xl">
      <div data-hero-el><Heading heading="Our Solutions" /></div>
      <h1 data-hero-el class="text-4xl md:text-6xl xl:text-7xl font-anton uppercase tracking-tight leading-none mb-6">
        Solar for Every Need
      </h1>
      <p data-hero-el class="text-primary/70 text-lg md:text-xl max-w-2xl font-grotesk">
        From grid-connected rooftops to off-grid farms and cold chain facilities — Techedge designs and installs the right solar solution for your specific requirements.
      </p>
    </div>
  </section>

  <!-- Solutions Grid -->
  <div class="relative z-10 bg-background-foreground">
    <section class="py-16 md:py-24">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 solutions-grid">
          {solutions.map((sol, i) => (
            <a
              href={`/solutions/${sol.slug}`}
              data-sol-card
              class="solution-card group bg-white rounded-2xl border border-muted/30 p-8 flex flex-col gap-4 relative overflow-hidden transition-all duration-300"
            >
              {/* accent line on hover */}
              <div class="card-accent absolute top-0 left-0 right-0 h-[3px] bg-secondary opacity-0 transition-opacity duration-300"></div>

              <div class="flex items-start justify-between">
                <div class="w-12 h-12 rounded-2xl bg-accent border border-secondary/30 flex items-center justify-center text-2xl">
                  {sol.icon}
                </div>
                <span class="text-xs font-bold uppercase tracking-widest text-muted-foreground mt-1">0{i + 1}</span>
              </div>

              <div>
                <h2 class="font-anton uppercase text-2xl md:text-3xl tracking-wide text-foreground leading-tight">
                  {sol.title}
                </h2>
                <p class="font-grotesk text-sm mt-1 text-secondary-foreground">{sol.tagline}</p>
              </div>

              <p class="text-muted-foreground text-sm leading-relaxed font-grotesk line-clamp-3">{sol.description}</p>

              <div class="grid grid-cols-2 gap-3 mt-2">
                {sol.highlights.map((h) => (
                  <div class="rounded-xl px-3 py-2 bg-accent border border-secondary/20">
                    <div class="text-[0.65rem] uppercase tracking-wider text-muted-foreground font-semibold">{h.label}</div>
                    <div class="text-sm font-bold mt-0.5 text-secondary-foreground">{h.value}</div>
                  </div>
                ))}
              </div>

              <div class="mt-auto flex items-center gap-2 font-semibold text-sm text-secondary-foreground transition-all duration-300 group-hover:gap-3 group-hover:text-secondary">
                Learn More <span>→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Cta />
  </div>
</Layout>

<style>
  .solution-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.10);
    border-color: var(--color-secondary);
  }
  .solution-card:hover .card-accent {
    opacity: 1;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll("[data-sol-card]");
  gsap.set(cards, { opacity: 0, y: 40 });
  gsap.to(cards, {
    opacity: 1,
    y: 0,
    duration: 0.7,
    ease: "power3.out",
    stagger: 0.15,
    scrollTrigger: {
      trigger: ".solutions-grid",
      start: "top 80%",
      toggleActions: "play none none none",
    },
  });
</script>
