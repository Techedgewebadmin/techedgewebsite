---
import Layout from "@/layouts/Layout.astro";
import { vsoleLV1ph, vsoleLV3ph, vsoleHV3ph, vsoleOngrid } from "@/data/vsole-products";

const color = '#a855f7';
const colorLight = 'rgba(168,85,247,0.10)';
const colorBorder = 'rgba(168,85,247,0.22)';
---

<Layout
  title="Vsole Hybrid & On-Grid Inverters India | 3kW–350kW | Techedge"
  description="Vsole hybrid and on-grid inverters — LV 48V single and three phase 3–20 kW, HV three phase 15–80 kW, on-grid up to 350 kW. Supply by Techedge Bengaluru."
  keywords="Vsole inverter India, Vsole hybrid inverter, Vsole on-grid inverter, solar inverter Bengaluru"
>

  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 border-b border-muted/10" style={`background:linear-gradient(135deg,#0a0a12 60%,${colorLight})`}>
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-6">
        <a href="/products/" class="text-muted text-sm hover:text-white">Products</a>
        <span class="text-muted/40">›</span>
        <span style={`color:${color}`} class="text-sm font-semibold">Vsole</span>
      </div>
      <span class="text-xs font-bold uppercase tracking-widest mb-3 block" style={`color:${color}`}>Supply Partner</span>
      <h1 class="font-anton text-5xl md:text-7xl uppercase text-white leading-none mb-4">Vsole</h1>
      <p class="text-muted text-lg max-w-2xl mb-8">
        Wide-range hybrid and on-grid solar inverters — from 3 kW residential single phase to 350 kW utility-scale three phase.
        LV (48V) and HV battery options, IP65 rated.
      </p>
      <div class="flex flex-wrap gap-3">
        {[
          [String(vsoleLV1ph.length + vsoleLV3ph.length), 'LV Hybrid Models'],
          [String(vsoleHV3ph.length), 'HV Hybrid Models'],
          ['3–350 kW', 'Power Range'],
          ['98.8%', 'Peak Efficiency'],
          ['IP65', 'Protection'],
        ].map(([v, l]) => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-xl px-5 py-3">
            <p class="text-xl font-grotesk font-bold text-white">{v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LV Single Phase Hybrid -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">LV Hybrid — Single Phase (48V)</h2>
      <p class="text-muted text-sm mb-8">3–20 kW · 48V battery · Residential and small commercial</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Battery','Efficiency','MPPT','Max PV V','Charge A','Warranty'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {vsoleLV1ph.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.name}</td>
                <td class="px-4 py-3 text-muted">{p.powerKW} kW</td>
                <td class="px-4 py-3 text-muted">{p.batteryVoltage}</td>
                <td class="px-4 py-3 text-muted">{p.maxEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.mpptCount}</td>
                <td class="px-4 py-3 text-muted">{p.maxPvVoltage} V</td>
                <td class="px-4 py-3 text-muted">{p.maxChargeCurrentA} A</td>
                <td class="px-4 py-3 text-muted">{p.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- LV Three Phase Hybrid -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">LV Hybrid — Three Phase (48V)</h2>
      <p class="text-muted text-sm mb-8">5–20 kW · 48V battery · Commercial premises</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Battery','Efficiency','MPPT','Max PV V','Charge A','Warranty'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {vsoleLV3ph.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.name}</td>
                <td class="px-4 py-3 text-muted">{p.powerKW} kW</td>
                <td class="px-4 py-3 text-muted">{p.batteryVoltage}</td>
                <td class="px-4 py-3 text-muted">{p.maxEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.mpptCount}</td>
                <td class="px-4 py-3 text-muted">{p.maxPvVoltage} V</td>
                <td class="px-4 py-3 text-muted">{p.maxChargeCurrentA} A</td>
                <td class="px-4 py-3 text-muted">{p.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- HV Three Phase Hybrid -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">HV Hybrid — Three Phase (High Voltage)</h2>
      <p class="text-muted text-sm mb-8">15–80 kW · HV battery · Large commercial and industrial</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Efficiency','MPPT','Max PV V','Charge A','Warranty'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {vsoleHV3ph.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.name}</td>
                <td class="px-4 py-3 text-muted">{p.powerKW} kW</td>
                <td class="px-4 py-3 text-muted">{p.maxEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.mpptCount}</td>
                <td class="px-4 py-3 text-muted">{p.maxPvVoltage} V</td>
                <td class="px-4 py-3 text-muted">{p.maxChargeCurrentA} A</td>
                <td class="px-4 py-3 text-muted">{p.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- On-Grid -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">On-Grid Inverters</h2>
      <p class="text-muted text-sm mb-8">1 kW–350 kW · Single and three phase · Grid-feed · Full commercial and utility range</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Phase','Efficiency','MPPT','Max PV V','Warranty'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {vsoleOngrid.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.name}</td>
                <td class="px-4 py-3 text-muted">{p.powerKW} kW</td>
                <td class="px-4 py-3 text-muted">{p.phases}ϕ</td>
                <td class="px-4 py-3 text-muted">{p.maxEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.mpptCount}</td>
                <td class="px-4 py-3 text-muted">{p.maxPvVoltage} V</td>
                <td class="px-4 py-3 text-muted">{p.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-4">Enquire About Vsole</h2>
      <p class="text-muted mb-8">Supply, installation and commissioning across Bengaluru and Karnataka.</p>
      <a href="/contact" class="inline-block font-anton text-lg uppercase px-8 py-4 rounded-xl transition-colors" style={`background:${color};color:white`}>
        Get a Quote →
      </a>
    </div>
  </section>

</Layout>
