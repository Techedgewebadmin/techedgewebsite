---
import Layout from "@/layouts/Layout.astro";
import { solintegProducts, solintegHybrid1ph, solintegHybrid3ph, solintegOngrid } from "@/data/solinteg-products";

const color = '#6366f1';
const colorLight = 'rgba(99,102,241,0.12)';
const colorBorder = 'rgba(99,102,241,0.25)';
---

<Layout
  title="Solinteg Hybrid & On-Grid Inverters India | BIS Certified | Techedge"
  description="Solinteg BIS-certified hybrid and on-grid inverters — single phase 3–8 kW, three phase 4–50 kW. MHS, MHT series. Supply by Techedge Bengaluru."
  keywords="Solinteg inverter India, Solinteg hybrid inverter BIS, Solinteg MHS MHT, solar inverter Bengaluru"
>

  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 border-b border-muted/10" style={`background:linear-gradient(135deg,#0a0a12 60%,${colorLight})`}>
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-6">
        <a href="/products/" class="text-muted text-sm hover:text-white transition-colors">Products</a>
        <span class="text-muted/40">›</span>
        <span style={`color:${color}`} class="text-sm font-semibold">Solinteg</span>
      </div>
      <div class="flex flex-wrap items-start justify-between gap-6 mb-8">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest mb-3 block" style={`color:${color}`}>Supply Partner</span>
          <h1 class="font-anton text-5xl md:text-7xl uppercase text-white leading-none mb-4">Solinteg</h1>
          <p class="text-muted text-lg max-w-2xl">
            BIS India certified hybrid and on-grid solar inverters. Single phase residential to three phase commercial — 3 kW to 50 kW.
            UPS-grade 10 ms switching, WiFi monitoring, and full generator support.
          </p>
        </div>
        <span class="text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border" style={`color:${color};background:${colorLight};border-color:${colorBorder}`}>BIS Certified</span>
      </div>
      <!-- Stat chips -->
      <div class="flex flex-wrap gap-3">
        {[
          ['14', 'Models'],
          ['3–50 kW', 'Power Range'],
          ['98.4%', 'Peak Efficiency'],
          ['10 ms', 'UPS Switching'],
          ['IP65', 'Protection'],
        ].map(([v, l]) => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-xl px-5 py-3">
            <p class="text-xl font-grotesk font-bold text-white">{v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Single Phase Hybrid -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">MHS Series — Single Phase Hybrid</h2>
      <p class="text-muted text-sm mb-8">3–8 kW · 1-phase · HV battery (85–450 V) · 30 A charge · Residential</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Efficiency','MPPT','Max PV V','Battery V','Charge A','IP','Warranty'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {solintegHybrid1ph.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.name.replace('Solinteg ','')}</td>
                <td class="px-4 py-3 text-muted">{p.powerKW} kW</td>
                <td class="px-4 py-3 text-muted">{p.maxEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.mpptCount}</td>
                <td class="px-4 py-3 text-muted">{p.maxPvVoltage} V</td>
                <td class="px-4 py-3 text-muted">{p.batteryVoltageRange}</td>
                <td class="px-4 py-3 text-muted">{p.maxChargeCurrentA} A</td>
                <td class="px-4 py-3 text-muted">{p.ipRating}</td>
                <td class="px-4 py-3 text-muted">{p.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Three Phase Hybrid -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">MHT Series — Three Phase Hybrid</h2>
      <p class="text-muted text-sm mb-8">4–50 kW · 3-phase · MHT-25/MHT-40 and commercial C&I range · Peak 98.4%</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Series','Efficiency','MPPT','Max PV V','Battery V','Charge A','Warranty'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {solintegHybrid3ph.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.name.replace('Solinteg ','')}</td>
                <td class="px-4 py-3 text-muted">{p.powerKW} kW</td>
                <td class="px-4 py-3 text-xs" style={`color:${color}`}>{p.series}</td>
                <td class="px-4 py-3 text-muted">{p.maxEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.mpptCount}</td>
                <td class="px-4 py-3 text-muted">{p.maxPvVoltage} V</td>
                <td class="px-4 py-3 text-muted">{p.batteryVoltageRange}</td>
                <td class="px-4 py-3 text-muted">{p.maxChargeCurrentA} A</td>
                <td class="px-4 py-3 text-muted">{p.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- On-Grid -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">OGS / OGT Series — On-Grid</h2>
      <p class="text-muted text-sm mb-8">1.5–25 kW · Single and three phase · BIS certified · Grid-feed only</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Phase','Efficiency','MPPT','Max PV V','Warranty'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {solintegOngrid.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.name.replace('Solinteg ','')}</td>
                <td class="px-4 py-3 text-muted">{p.powerKW} kW</td>
                <td class="px-4 py-3 text-muted">{p.phases}ϕ</td>
                <td class="px-4 py-3 text-muted">{p.maxEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.mpptCount}</td>
                <td class="px-4 py-3 text-muted">{p.maxPvVoltage} V</td>
                <td class="px-4 py-3 text-muted">{p.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Key Features -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-10">Why Solinteg</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        {[
          ['BIS India Certified', 'Approved for DISCOM net metering applications across India.'],
          ['10 ms UPS Switching', 'Near-instant transfer — critical loads see no interruption.'],
          ['98.4% Peak Efficiency', 'MHT-HV series delivers top-tier conversion efficiency.'],
          ['HV Battery Compatible', 'Works with high-voltage LiFePO4 stacks up to 750 V.'],
          ['WiFi + RS485', 'Built-in wireless monitoring; RS485 for professional SCADA.'],
          ['Generator Support', 'Seamless integration with diesel generators for off-grid or backup.'],
        ].map(([title, desc]) => (
          <div class="rounded-2xl p-6 border" style={`background:${colorLight};border-color:${colorBorder}`}>
            <p class="font-bold text-foreground mb-2">{title}</p>
            <p class="text-muted text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-4">Enquire About Solinteg</h2>
      <p class="text-muted mb-8">Supply, installation and commissioning across Bengaluru and Karnataka. Contact Techedge for pricing and availability.</p>
      <a href="/contact" class="inline-block font-anton text-lg uppercase px-8 py-4 rounded-xl transition-colors" style={`background:${color};color:white`}>
        Get a Quote →
      </a>
    </div>
  </section>

</Layout>
