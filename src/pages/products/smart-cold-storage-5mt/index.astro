---
import Layout from "@/layouts/Layout.astro";
import { coldStorageProducts } from "@/data/cold-storage-products";

const color = '#0891b2';
const colorLight = 'rgba(8,145,178,0.12)';
const colorBorder = 'rgba(8,145,178,0.25)';

const p = coldStorageProducts.find(c => c.slug === 'smart-solar-cold-storage-5mt')!;
const other = coldStorageProducts.find(c => c.slug === 'smart-solar-cold-storage-10mt')!;

const formatPrice = (n: number) =>
  new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(n);

const schema = {
  "@context": "https://schema.org", "@type": "Product",
  "name": p.name, "description": p.seoDescription,
  "brand": { "@type": "Brand", "name": "Techedge" },
  "offers": {
    "@type": "Offer", "priceCurrency": "INR",
    "price": p.totalPriceInclGst.toFixed(2),
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge SPE India Pvt. Ltd." }
  },
};
---

<Layout
  title={p.seoTitle}
  description={p.seoDescription}
  keywords="solar cold storage India, portable cold room solar, 5MT cold storage price, hybrid solar cold storage FPO, LiFePO4 cold storage battery, off-grid cold room India"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 border-b border-muted/10" style={`background:linear-gradient(135deg,#0a0a12 60%,${colorLight})`}>
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-6">
        <a href="/products/" class="text-muted text-sm hover:text-foreground transition-colors">Products</a>
        <span class="text-muted/40">›</span>
        <span style={`color:${color}`} class="text-sm font-semibold">Smart Solar Cold Storage</span>
      </div>
      <div class="flex flex-wrap items-start justify-between gap-6 mb-8">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest mb-3 block" style={`color:${color}`}>Portable · Outdoor · Techedge Brand</span>
          <h1 class="font-anton text-5xl md:text-7xl uppercase text-white leading-none mb-4">5MT Cold Storage</h1>
          <p class="text-muted text-lg max-w-2xl">
            A fully portable, outdoor-ready solar hybrid cold room — no permanent building required.
            Solar by day, LiFePO₄ battery by night, with automatic grid backup. Built for FPOs, farmers, and rural cold chain aggregation points.
          </p>
        </div>
        <span class="text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border" style={`color:${color};background:${colorLight};border-color:${colorBorder}`}>Solar Hybrid</span>
      </div>
      <!-- Stat chips -->
      <div class="flex flex-wrap gap-3">
        {[
          [`${p.capacityMT} MT`, 'Storage Capacity'],
          [`${p.solarKWp} kWp`, 'Solar PV'],
          [`${p.batteryKWh} kWh`, 'LiFePO₄ Battery'],
          [p.tempRange, 'Temp Range'],
          [p.warranty.split(',')[0], 'Warranty'],
        ].map(([v, l]) => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-xl px-5 py-3">
            <p class="text-xl font-grotesk font-bold text-white">{v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div>
        <h2 class="font-anton text-3xl uppercase text-foreground mb-6">Indicative EPC Pricing</h2>
        <div class="rounded-2xl border-2 p-6" style={`border-color:${colorBorder};background:${colorLight}`}>
          <p class="text-xs uppercase font-bold text-muted tracking-widest mb-1">Total Price (incl. GST)</p>
          <p class="text-4xl font-grotesk font-bold mb-1" style={`color:${color}`}>{formatPrice(p.totalPriceInclGst)}</p>
          <p class="text-xs text-muted mb-5">Supply + installation & commissioning, within 400km of Bengaluru</p>
          <div class="bg-background/40 rounded-xl px-4 py-3 mb-5 text-sm space-y-1">
            <div class="flex justify-between"><span class="text-muted">Goods (70% value) — 5% GST</span><span class="text-foreground font-semibold">{formatPrice(p.goodsValue)}</span></div>
            <div class="flex justify-between"><span class="text-muted">Installation (30% value) — 18% GST</span><span class="text-foreground font-semibold">{formatPrice(p.servicesValue)}</span></div>
          </div>
          <div class="space-y-2 text-xs text-muted mb-5">
            <p>✓ GST calculated per Notification No. 01/2017 &amp; 11/2017-Central Tax (Rate) — 70:30 composite supply split</p>
            <p>✓ Delivery {p.deliveryWeeks} · Installation {p.installationDays}</p>
            <p>✓ Payment: 50% advance with PO, 50% before dispatch</p>
            <p>✓ Indicative pricing — subject to site survey and current quotation</p>
          </div>
          <a href="/contact" class="block w-full font-anton text-lg uppercase text-center py-4 rounded-xl transition-colors" style={`background:${color};color:white`}>
            Get a Quote
          </a>
        </div>
      </div>
      <div>
        <h2 class="font-anton text-3xl uppercase text-foreground mb-6">System Overview</h2>
        <div class="overflow-x-auto rounded-2xl border border-muted/10">
          <table class="w-full text-sm">
            <tbody>
              {[
                ['Refrigeration', `${p.compressorTR} TR inverter duty scroll compressor`],
                ['Solar PV', `${p.solarKWp} kWp N-Type TOPCon`],
                ['Hybrid Inverter', `${p.inverterKW} kW, ${p.inverterPhase}`],
                ['Battery', `${p.batteryKWh} kWh — ${p.batteryModules}`],
                ['Insulation', p.panelInsulation],
                ['Operating Range', p.tempRange],
                ['Monitoring', 'IoT / mobile app — temperature, solar generation, battery status'],
                ['Warranty', p.warranty],
              ].map(([label, val]) => (
                <tr class="odd:bg-muted-foreground/5">
                  <td class="px-4 py-3 font-semibold text-foreground w-1/3">{label}</td>
                  <td class="px-4 py-3 text-muted">{val}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Scope of Supply -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div>
        <h2 class="font-anton text-3xl uppercase text-foreground mb-6">Scope of Supply</h2>
        <ul class="space-y-3">
          {p.scopeOfSupply.map(item => (
            <li class="flex items-start gap-3 text-sm text-muted">
              <span class="mt-0.5 shrink-0 font-bold" style={`color:${color}`}>✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="font-anton text-3xl uppercase text-foreground mb-6">Exclusions</h2>
        <ul class="space-y-3 mb-8">
          {p.exclusions.map(item => (
            <li class="flex items-start gap-3 text-sm text-muted">
              <span class="mt-0.5 shrink-0 text-muted/50">–</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <p class="text-xs text-muted">
          Full scope, exclusions and terms confirmed in the formal quotation issued against your site requirement.
        </p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-10">Why This System</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-10">
        {p.features.map(f => (
          <div class="rounded-2xl p-6 border" style={`background:${colorLight};border-color:${colorBorder}`}>
            <p class="text-muted text-sm">{f}</p>
          </div>
        ))}
      </div>
      <h3 class="font-grotesk font-bold text-foreground text-lg mb-4 uppercase tracking-wide">Ideal For</h3>
      <div class="flex flex-wrap gap-2">
        {p.useCases.map(uc => (
          <span class="text-xs bg-muted-foreground/10 border border-muted/20 px-3 py-1.5 rounded-full text-muted">{uc}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Buying guide link -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto rounded-2xl border p-8 flex flex-wrap items-center justify-between gap-6" style={`background:${colorLight};border-color:${colorBorder}`}>
      <div>
        <p class="text-xs font-bold uppercase tracking-widest mb-2" style={`color:${color}`}>Buyer's Guide</p>
        <h3 class="font-anton text-2xl uppercase text-foreground mb-2">Not sure which system is right for your farm?</h3>
        <p class="text-muted text-sm max-w-xl">Read our full guide comparing solar hybrid lithium, traditional grid/DG, and thermal storage cold rooms for 5 MT and 10 MT farm use.</p>
      </div>
      <a href="/blog/solar-cold-storage-buying-guide-farmers" class="shrink-0 inline-block font-anton text-sm uppercase px-6 py-3 rounded-xl transition-colors" style={`background:${color};color:white`}>
        Read the Guide →
      </a>
    </div>
  </section>

  <!-- Other capacity -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <a href={`/products/${other.slug}/`} class="group block rounded-2xl border border-muted/20 p-6 hover:border-muted/40 transition-colors flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-xs text-muted uppercase font-semibold mb-1">Need more capacity?</p>
          <p class="font-anton text-xl uppercase text-foreground">{other.name}</p>
        </div>
        <span class="font-anton text-sm uppercase" style={`color:${color}`}>View 10MT System →</span>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-4">Enquire About the 5MT Cold Storage</h2>
      <p class="text-muted mb-8">Site survey, load assessment, SELCO/AIF grant documentation support, and pan-India installation by Techedge.</p>
      <a href="/contact" class="inline-block font-anton text-lg uppercase px-8 py-4 rounded-xl transition-colors" style={`background:${color};color:white`}>
        Get a Quote →
      </a>
    </div>
  </section>

</Layout>
