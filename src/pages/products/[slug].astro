                  <li class="flex items-start gap-3">
                    <span class="mt-1 shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold" style={`background:${heroBrandColor}25; color:${heroBrandColor}`}>✓</span>
                    <span class="text-muted text-sm leading-relaxed">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h2 class="font-anton text-xl uppercase text-foreground mb-4">Ideal For</h2>
              <div class="flex flex-wrap gap-2">
                {heroUseCases.map(uc => (
                  <span class="text-xs bg-muted-foreground/10 border border-muted/20 px-3 py-1.5 rounded-full text-muted">{uc}</span>
                ))}
              </div>
            </div>
          </div>

          <div class="lg:col-span-5">
            <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-6 mb-6">
              <h3 class="font-anton text-lg uppercase text-foreground mb-4">Specifications</h3>
              <dl class="space-y-3">
                {newBrandSpecRows.map(([label, val]) => (
                  <div class="flex items-start justify-between gap-4 py-2 border-b border-muted/10 last:border-0">
                    <dt class="text-xs uppercase text-muted font-semibold tracking-wide shrink-0">{label}</dt>
                    <dd class="text-sm text-foreground font-semibold text-right">{val}</dd>
                  </div>
                ))}
              </dl>
            </div>

            <div class="bg-muted-foreground/5 border-2 rounded-2xl p-6 mb-6" style={`border-color:${heroBrandColor}40`}>
              <h3 class="font-anton text-lg uppercase text-foreground mb-2">Pricing</h3>
              <p class="text-2xl font-grotesk font-bold text-foreground mb-1">Contact for Quote</p>
              <p class="text-xs text-muted mb-5">Per-unit pricing on enquiry · GST extra · EPC supply available</p>
              <a href="/contact" class="block w-full text-center font-anton text-base uppercase py-3 rounded-xl transition-colors" style={`background:${heroBrandColor}; color:#fff`}>
                Get a Quote
              </a>
            </div>

            {newBrandCerts.length > 0 && (
              <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-6">
                <h3 class="font-anton text-lg uppercase text-foreground mb-3">Certifications</h3>
                <div class="flex flex-wrap gap-2">
                  {newBrandCerts.map(c => (
                    <span class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-muted-foreground/10 text-muted">{c}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </section>
    </>
  )}

  <!-- Related products (shared) -->
  {related.length > 0 && (
