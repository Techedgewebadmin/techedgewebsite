            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="text-sm font-bold uppercase tracking-widest px-3 py-1 rounded-full" style={`color:${heroBrandColor}; background:${heroBrandColor}18;`}>
                {heroBrand}
              </span>
              <span class="text-xs font-semibold uppercase text-muted bg-muted-foreground/10 px-3 py-1 rounded-full">Supply Partner</span>
            </div>
            <h1 class="font-anton text-3xl md:text-5xl uppercase text-foreground leading-none mb-3">{heroName}</h1>
            <p class="font-mono text-sm text-muted mb-6">Model: <span class="text-foreground font-semibold">{heroModel}</span></p>
            <div class="flex flex-wrap gap-3 mb-8">
              {heroStats.map(s => (
                <div class="rounded-xl px-4 py-2 text-center" style={`background:${heroBrandColor}18; border:1px solid ${heroBrandColor}40;`}>
                  <p class="text-xl font-bold" style={`color:${heroBrandColor}`}>{s.value}</p>
                  <p class="text-[10px] uppercase text-muted font-semibold">{s.label}</p>
                </div>
              ))}
            </div>
            <p class="text-muted leading-relaxed mb-8">{heroDesc}</p>
            <div class="mb-8">
