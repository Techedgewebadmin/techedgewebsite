                  <p class="text-muted text-xs font-mono mb-2">{r.model}</p>
                  <p class="text-sm text-muted">{r.powerW} W · {r.peakEfficiency}% eff.</p>
                  <p class="text-lg font-bold mt-2" style="color:#ef4444;">₹{r.sellingPrice.toLocaleString('en-IN')}</p>
                  <p class="text-[10px] text-muted">+ 12% GST</p>
                </a>
              ))
            : isNewBrand
            ? (related as any[]).map(r => (
                <a href={`/products/${(r as any).slug ?? ''}/`} class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border border-muted/20 rounded-2xl p-5 transition-all" style={`border-color:${heroBrandColor}33`}>
                  <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full" style={`color:${heroBrandColor}; background:${heroBrandColor}18;`}>{heroBrand}</span>
                  <h3 class="font-grotesk font-bold text-foreground text-sm leading-snug mt-3 mb-1 group-hover:text-secondary transition-colors">{r.name}</h3>
                  {(r as any).model && <p class="text-muted text-xs font-mono mb-2">{(r as any).model}</p>}
                  <p class="text-[10px] text-muted mt-1">Contact for price</p>
                </a>
              ))
            : (related as TechedgeProduct[]).map(r => (
                <a href={`/products/${r.slug}/`} class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border border-muted/20 hover:border-secondary/40 rounded-2xl p-5 transition-all">
                  <span class="text-[10px] font-bold uppercase tracking-widest text-secondary bg-secondary/10 px-2 py-0.5 rounded-full">{r.subcategory}</span>
                  <h3 class="font-grotesk font-bold text-foreground text-sm leading-snug mt-3 mb-1 group-hover:text-secondary transition-colors">{r.name}</h3>
                  <p class="text-muted text-xs mb-2">{r.backupHours}hr · {r.batterySpec}</p>
                  <p class="text-lg font-bold text-secondary">{formatPrice(r.sellingPrice)}</p>
                  <p class="text-[10px] text-muted">excl. 12% GST · MOQ 25</p>
                </a>
              ))
          }
        </div>
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="py-20 px-4 bg-secondary/5 border-t border-muted/10">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mb-4">
        {isDeye || isGoldi || isHoymiles || isTsun || isNewBrand ? 'Ready to Go Solar?' : 'Need Bulk Pricing or Custom Branding?'}
      </h2>
      <p class="text-muted mb-8">
        {isDeye || isGoldi || isHoymiles || isTsun || isNewBrand
          ? 'Get a free site survey and customised system design from Techedge — Bengaluru\'s trusted solar EPC partner with 200+ installations.'
          : 'Contact Techedge for MOQ pricing, custom packaging, NGO/CSR program documentation and pan-India delivery.'}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-secondary text-black font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-secondary/90 transition-colors">
          {isDeye || isGoldi || isHoymiles || isTsun || isNewBrand ? 'Get a Free Site Survey' : 'Get Bulk Quote'}
        </a>
        <a href={isDeye || isGoldi || isHoymiles || isTsun || isNewBrand ? '/projects' : '/solutions/microgrid-solar/'} class="bg-muted-foreground/10 text-foreground font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-muted-foreground/20 transition-colors border border-muted/30">
          {isDeye || isGoldi || isHoymiles || isTsun || isNewBrand ? 'See Our Projects' : 'Microgrid Solution'}
        </a>
      </div>
    </div>
  </section>

</Layout>
