---
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import { deyeProducts, type DeyeProduct } from "@/data/deye-products";
import { allTechedgeProducts, type TechedgeProduct } from "@/data/techedge-products";
import { goldiProducts, type GoldiProduct } from "@/data/goldi-products";
import { hoymilesProducts, type HoymilesProduct } from "@/data/hoymiles-products";
import { tsunProducts, type TsunProduct } from "@/data/tsun-products";
import { solintegProducts, type SolintegProduct } from "@/data/solinteg-products";
import { vsoleProducts, type VsoleProduct } from "@/data/vsole-products";
import { renewSysProducts, type RenewSysProduct } from "@/data/renewsys-products";
import { rayzonProducts, type RayzonProduct } from "@/data/rayzon-products";
import { lithiumValleyProducts, type LithiumValleyProduct } from "@/data/lithium-valley-products";
import { bplPowerzenProducts, type BplPowerzenProduct } from "@/data/bpl-powerzen-products";

export const prerender = true;

type ProductType = 'deye' | 'techedge' | 'goldi' | 'hoymiles' | 'tsun' | 'solinteg' | 'vsole' | 'renewsys' | 'rayzon' | 'lithiumValley' | 'bpl';

type ProductProps = {
  productType: ProductType;
  product: DeyeProduct | null;
  teProduct: TechedgeProduct | null;
  goldiProduct: GoldiProduct | null;
  hoymilesProduct: HoymilesProduct | null;
  tsunProduct: TsunProduct | null;
  solintegProduct: SolintegProduct | null;
  vsoleProduct: VsoleProduct | null;
  renewsysProduct: RenewSysProduct | null;
  rayzonProduct: RayzonProduct | null;
  lithiumValleyProduct: LithiumValleyProduct | null;
  bplProduct: BplPowerzenProduct | null;
};

export const getStaticPaths = (() => {
  const emptyProps: Omit<ProductProps, 'productType'> = {
    product: null, teProduct: null, goldiProduct: null, hoymilesProduct: null, tsunProduct: null,
    solintegProduct: null, vsoleProduct: null, renewsysProduct: null, rayzonProduct: null,
    lithiumValleyProduct: null, bplProduct: null,
  };
  const deyePaths = deyeProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'deye' as const, product: p } }));
  const tePaths = allTechedgeProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'techedge' as const, teProduct: p } }));
  const goldiPaths = goldiProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'goldi' as const, goldiProduct: p } }));
  const hoymilesPathsList = hoymilesProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'hoymiles' as const, hoymilesProduct: p } }));
  const tsunPathsList = tsunProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'tsun' as const, tsunProduct: p } }));
  const solintegPaths = solintegProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'solinteg' as const, solintegProduct: p } }));
  const vsolePaths = vsoleProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'vsole' as const, vsoleProduct: p } }));
  const renewsysPaths = renewSysProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'renewsys' as const, renewsysProduct: p } }));
  const rayzonPaths = rayzonProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'rayzon' as const, rayzonProduct: p } }));
  const lithiumValleyPaths = lithiumValleyProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'lithiumValley' as const, lithiumValleyProduct: p } }));
  const bplPaths = bplPowerzenProducts.map(p => ({ params: { slug: p.slug }, props: { ...emptyProps, productType: 'bpl' as const, bplProduct: p } }));
  return [...deyePaths, ...tePaths, ...goldiPaths, ...hoymilesPathsList, ...tsunPathsList, ...solintegPaths, ...vsolePaths, ...renewsysPaths, ...rayzonPaths, ...lithiumValleyPaths, ...bplPaths];
}) satisfies GetStaticPaths;

const {
  productType, product: dp, teProduct: tp, goldiProduct: gp, hoymilesProduct: hp, tsunProduct: sp,
  solintegProduct: sop, vsoleProduct: vop, renewsysProduct: rnp, rayzonProduct: ryp,
  lithiumValleyProduct: lvp, bplProduct: bpp,
} = Astro.props as ProductProps;

const isDeye = productType === 'deye';
const isGoldi = productType === 'goldi';
const isHoymiles = productType === 'hoymiles';
const isTsun = productType === 'tsun';
const isSolinteg = productType === 'solinteg';
const isVsole = productType === 'vsole';
const isRenewSys = productType === 'renewsys';
const isRayzon = productType === 'rayzon';
const isLithiumValley = productType === 'lithiumValley';
const isBpl = productType === 'bpl';
const isNewBrand = isSolinteg || isVsole || isRenewSys || isRayzon || isLithiumValley || isBpl;
const p = dp!;
const t = tp!;
const g = gp!;

// ── New-brand derived copy (these data models don't carry features/useCases/SEO fields) ──
const newBrandMeta: Record<string, { label: string; color: string; useCases: string[] }> = {
  solinteg: { label: 'Solinteg', color: '#6366f1', useCases: ['Residential rooftop solar backup', 'Commercial & industrial hybrid installations', 'Grid-tied net metering with battery backup', 'C&I peak-shaving and demand management'] },
  vsole: { label: 'Vsole', color: '#a855f7', useCases: ['Residential rooftop solar', 'Commercial & industrial installations', 'Grid-tied and hybrid backup systems', 'Utility-scale on-grid projects'] },
  renewsys: { label: 'RenewSys', color: '#f59e0b', useCases: ['Residential rooftop', 'Commercial & industrial rooftop', 'Ground-mount utility projects', 'DCR/subsidy-linked government projects'] },
  rayzon: { label: 'Rayzon', color: '#94a3b8', useCases: ['Residential rooftop', 'Commercial & industrial rooftop', 'Ground-mount utility projects', 'ALMM-listed government/subsidy projects'] },
  lithiumValley: { label: 'Lithium Valley', color: '#14b8a6', useCases: ['Residential battery backup', 'Commercial & industrial energy storage', 'Hybrid solar systems', 'Peak shaving & demand management'] },
  bpl: { label: 'BPL PowerZen', color: '#2563eb', useCases: ['Edge & small data centres', 'Commercial & industrial critical infrastructure', 'UPS replacement with solar offset', 'Backup power for offices & retail'] },
};

const vsoleFeatures = (v: VsoleProduct) => [
  `${v.maxEfficiency}% max efficiency across ${v.mpptCount} MPPT tracker${v.mpptCount > 1 ? 's' : ''}`,
  v.type === 'hybrid' ? `Battery-ready — ${v.batteryVoltage} battery voltage, up to ${v.maxChargeCurrentA}A charge current` : 'Grid-tied on-grid inverter, no battery required',
  `${v.ipRating}-rated enclosure, ${v.warranty} warranty`,
];
const panelFeatures = (m: RenewSysProduct | RayzonProduct) => [
  `${m.moduleEfficiency}% module efficiency, ${m.bifacial ? 'bifacial' : 'monofacial'} ${m.cellType}`,
  `${m.productWarranty} product warranty, ${m.performanceWarranty} performance warranty`,
  `Made in India${m.almm ? ', ALMM listed' : ''}`,
];

const formatPrice = (n: number) =>
  new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(n);

// ── DEYE helpers ──────────────────────────────────────────────────────────────
const catIcon: Record<string, string> = {
  'On-Grid': '⚡', 'Micro': '🔲', 'Hybrid': '🔋', 'Battery': '🏭', 'All-in-One': '📦',
};

const specLabels: Record<string, string> = {
  efficiency: 'Max Efficiency', ipRating: 'Protection Rating',
  mpptTrackers: 'MPPT Trackers', mpptVoltage: 'MPPT Voltage Range',
  maxInputVoltage: 'Max DC Input Voltage', batteryVoltage: 'Battery Voltage Range',
  dimensions: 'Dimensions (W×H×D)', weight: 'Weight', chemistry: 'Battery Chemistry',
  nominalCapacity: 'Nominal Capacity', nominalVoltage: 'Nominal Voltage', cycleLife: 'Cycle Life',
  usableEnergy: 'Usable Energy', systemNominalVoltage: 'System Voltage',
  moduleEnergy: 'Module Energy', moduleVoltage: 'Module Voltage',
  moduleCapacity: 'Module Capacity', modulesInSystem: 'Modules in System',
  chargeCurrentRecommended: 'Charge Current (Rec.)', chargeCurrentMax: 'Charge Current (Max)',
  recommendedDoD: 'Recommended DoD', operatingTempDischarge: 'Operating Temp (Discharge)',
  operatingTempCharge: 'Operating Temp (Charge)', storageTemp: 'Storage Temperature',
  thermalManagement: 'Thermal Management', systemWeight: 'System Weight',
  communication: 'Communication', display: 'Display', altitude: 'Max Altitude',
  humidity: 'Humidity', certification: 'Certification',
  ratedAcPower: 'Rated AC Power', maxApparentPower: 'Max Apparent Power',
  acVoltage: 'AC Voltage', gridFrequency: 'Grid Frequency',
  powerFactor: 'Power Factor', thd: 'THD', cooling: 'Cooling',
  topology: 'Topology', scalability: 'Scalability', peakPowerSupport: 'Peak Power Support',
  euroEfficiency: 'Euro Efficiency', batteryVoltageRange: 'Battery Voltage Range',
  maxChargeCurrent: 'Max Charge Current', maxDischargeCurrent: 'Max Discharge Current',
  operatingTemp: 'Operating Temperature',
};

const deyeHasSpecs = isDeye && Object.keys(p.specs).length > 0 && Object.values(p.specs).some(v => v !== undefined);
const related = isDeye
  ? deyeProducts.filter(r => r.category === p.category && r.id !== p.id).slice(0, 4)
  : isGoldi
    ? goldiProducts.filter(r => r.id !== g.id).slice(0, 4)
    : isHoymiles
      ? hoymilesProducts.filter(r => r.series === hp!.series && r.id !== hp!.id).slice(0, 4)
      : isTsun
        ? tsunProducts.filter(r => r.id !== sp!.id).slice(0, 4)
        : isSolinteg
          ? solintegProducts.filter(r => r.type === sop!.type && r.id !== sop!.id).slice(0, 4)
          : isVsole
            ? vsoleProducts.filter(r => r.type === vop!.type && r.id !== vop!.id).slice(0, 4)
            : isRenewSys
              ? renewSysProducts.filter(r => r.id !== rnp!.id).slice(0, 4)
              : isRayzon
                ? rayzonProducts.filter(r => r.id !== ryp!.id).slice(0, 4)
                : isLithiumValley
                  ? lithiumValleyProducts.filter(r => r.series === lvp!.series && r.id !== lvp!.id).slice(0, 4)
                  : isBpl
                    ? []
                    : allTechedgeProducts.filter(r => r.category === t.category && r.id !== t.id).slice(0, 4);
const priceWithGst = isDeye ? Math.round(p.sellingPrice * (1 + p.gstRate / 100)) : 0;

// ── HERO SLIDE DATA (unified across all brands) ─────────────────────────
const heroName  = isDeye ? dp!.name  : isGoldi ? gp!.name  : isHoymiles ? hp!.name  : isTsun ? sp!.name
  : isSolinteg ? sop!.name : isVsole ? vop!.name : isRenewSys ? rnp!.name : isRayzon ? ryp!.name
  : isLithiumValley ? lvp!.name : isBpl ? bpp!.name : tp!.name;
const heroModel = isDeye ? dp!.model : isGoldi ? gp!.model : isHoymiles ? hp!.model : isTsun ? sp!.model
  : isSolinteg ? sop!.name : isVsole ? vop!.name : isRenewSys ? rnp!.model : isRayzon ? ryp!.model
  : isLithiumValley ? lvp!.model : isBpl ? bpp!.model : tp!.model;
const heroBrand = isDeye ? 'Deye' : isGoldi ? 'Goldi Solar' : isHoymiles ? 'Hoymiles' : isTsun ? 'TSUN'
  : isNewBrand ? newBrandMeta[productType].label : 'Techedge';
const heroBrandColor = isDeye ? '#f97316' : isGoldi ? '#eab308' : isHoymiles ? '#06b6d4' : isTsun ? '#ef4444'
  : isNewBrand ? newBrandMeta[productType].color : '#86efac';

const heroStats: { value: string; label: string }[] = isDeye ? [
  ...(dp!.specs.efficiency ? [{ value: dp!.specs.efficiency, label: 'Max Efficiency' }] : []),
  ...(dp!.specs.ipRating   ? [{ value: dp!.specs.ipRating,   label: 'IP Rating' }]      : []),
  ...(dp!.specs.mpptTrackers ? [{ value: String(dp!.specs.mpptTrackers), label: 'MPPT Trackers' }] : []),
  { value: dp!.warranty, label: 'Warranty' },
].slice(0, 4) : isGoldi ? [
  { value: `${gp!.efficiency}%`,         label: 'Efficiency' },
  { value: `${gp!.powerWp} Wp`,          label: 'Power (STC)' },
  { value: gp!.performanceWarranty,       label: 'Performance' },
  { value: gp!.productWarranty,           label: 'Product Warranty' },
] : isHoymiles ? [
  { value: `${hp!.maxEfficiency}%`, label: 'Max Efficiency' },
  { value: hp!.ipRating,             label: 'IP Rating' },
  { value: `${hp!.pvInputs} input${hp!.pvInputs > 1 ? 's' : ''}`, label: 'PV Inputs' },
  { value: hp!.warranty,             label: 'Warranty' },
] : isTsun ? [
  { value: `${sp!.peakEfficiency}%`, label: 'Peak Efficiency' },
  { value: sp!.ipRating,             label: 'IP Rating' },
  { value: 'BIS ✓',                  label: 'India Certified' },
  { value: sp!.warranty,             label: 'Warranty' },
] : isSolinteg ? [
  { value: `${sop!.powerKW} kW`,        label: 'Rated Power' },
  { value: `${sop!.maxEfficiency}%`,    label: 'Max Efficiency' },
  { value: `${sop!.mpptCount} MPPT`,    label: 'MPPT Trackers' },
  { value: sop!.warranty,               label: 'Warranty' },
] : isVsole ? [
  { value: `${vop!.powerKW} kW`,        label: 'Rated Power' },
  { value: `${vop!.maxEfficiency}%`,    label: 'Max Efficiency' },
  { value: `${vop!.phases}-Phase`,      label: 'Phase' },
  { value: vop!.warranty,               label: 'Warranty' },
] : isRenewSys ? [
  { value: `${rnp!.powerWp} Wp`,           label: 'Power (STC)' },
  { value: `${rnp!.moduleEfficiency}%`,    label: 'Efficiency' },
  { value: rnp!.performanceWarranty,       label: 'Performance' },
  { value: rnp!.productWarranty,           label: 'Product Warranty' },
] : isRayzon ? [
  { value: `${ryp!.powerWp} Wp`,           label: 'Power (STC)' },
  { value: `${ryp!.moduleEfficiency}%`,    label: 'Efficiency' },
  { value: ryp!.performanceWarranty,       label: 'Performance' },
  { value: ryp!.productWarranty,           label: 'Product Warranty' },
] : isLithiumValley ? [
  { value: `${lvp!.capacityKWh} kWh`,      label: 'Module Capacity' },
  { value: `${lvp!.maxCapacityKWh} kWh`,   label: 'Max Stacked' },
  { value: `${lvp!.cycleLife.toLocaleString()}`, label: 'Cycle Life' },
  { value: lvp!.warranty,                  label: 'Warranty' },
] : isBpl ? [
  { value: `${bpp!.powerKW} kW`,           label: 'Rated Power' },
  { value: `${bpp!.batteryKWh} kWh`,       label: 'Battery' },
  { value: `${bpp!.cycleLife.toLocaleString()}`, label: 'Cycle Life' },
  { value: bpp!.warranty,                  label: 'Warranty' },
] : [
  { value: `${tp!.backupHours} hrs`,      label: 'Backup Time' },
  { value: tp!.batterySpec,               label: 'Battery' },
  { value: tp!.panelSpec,                 label: 'Solar Panel' },
  ...(tp!.loadSpec ? [{ value: tp!.loadSpec, label: 'Load' }] : []),
].slice(0, 4);

const heroFeatures = (
  isDeye ? dp!.features : isGoldi ? gp!.features : isHoymiles ? hp!.features : isTsun ? sp!.features
  : isSolinteg ? sop!.features : isVsole ? vsoleFeatures(vop!) : isRenewSys ? panelFeatures(rnp!)
  : isRayzon ? panelFeatures(ryp!) : isLithiumValley ? lvp!.features : isBpl ? bpp!.features : tp!.features
).slice(0, 3);
const heroUseCases = isDeye ? dp!.useCases : isGoldi ? gp!.useCases : isHoymiles ? hp!.useCases : isTsun ? sp!.useCases
  : isNewBrand ? newBrandMeta[productType].useCases : tp!.useCases;
const heroDesc = isDeye ? dp!.seoDescription : isGoldi ? gp!.seoDescription : isHoymiles ? hp!.seoDescription : isTsun ? sp!.seoDescription
  : isSolinteg ? `Solinteg ${sop!.name} — ${sop!.powerKW}kW ${sop!.type.includes('hybrid') ? 'hybrid' : 'on-grid'} inverter, ${sop!.maxEfficiency}% max efficiency, ${sop!.ipRating} rated. BIS India certified. Supply and installation by Techedge.`
  : isVsole ? `Vsole ${vop!.name} — ${vop!.powerKW}kW ${vop!.type} inverter, ${vop!.maxEfficiency}% max efficiency, ${vop!.ipRating} rated, ${vop!.warranty} warranty. Supply by Techedge India.`
  : isRenewSys ? `RenewSys ${rnp!.name} — ${rnp!.moduleEfficiency}% efficiency N-type TOPCon module, ALMM listed${rnp!.dcr ? ', DCR compliant' : ''}, made in India. ${rnp!.productWarranty} product / ${rnp!.performanceWarranty} performance warranty.`
  : isRayzon ? `Rayzon ${ryp!.name} — ${ryp!.moduleEfficiency}% efficiency N-type TOPCon bifacial module, ALMM listed, made in India. ${ryp!.productWarranty} product / ${ryp!.performanceWarranty} performance warranty.`
  : isLithiumValley ? `Lithium Valley ${lvp!.name} — ${lvp!.capacityKWh}kWh LiFePO4 module (stackable to ${lvp!.maxCapacityKWh}kWh), ${lvp!.cycleLife.toLocaleString()} cycle life, ${lvp!.warranty} warranty. BIS certified. Supply by Techedge India.`
  : isBpl ? `BPL PowerZen ${bpp!.name} — all-in-one hybrid inverter with integrated ${bpp!.batteryKWh}kWh LiFePO4 battery, ${bpp!.cycleLife.toLocaleString()} cycle life, ${bpp!.warranty} warranty. BIS certified. Supply by Techedge India.`
  : tp!.seoDescription;
const heroTitle = isNewBrand ? `${heroName} — ${heroModel} | Techedge India` : '';

const newBrandSpecRows: [string, string][] = isSolinteg ? [
  ['Series', sop!.series],
  ['Rated Power', `${sop!.powerKW} kW`],
  ['Phases', String(sop!.phases)],
  ['Max Efficiency', `${sop!.maxEfficiency}%`],
  ['MPPT Trackers', String(sop!.mpptCount)],
  ['Max PV Voltage', `${sop!.maxPvVoltage} V`],
  ...(sop!.batteryVoltageRange ? [['Battery Voltage Range', sop!.batteryVoltageRange] as [string, string]] : []),
  ...(sop!.maxChargeCurrentA ? [['Max Charge Current', `${sop!.maxChargeCurrentA} A`] as [string, string]] : []),
  ['AC Voltage', sop!.acVoltage],
  ['IP Rating', sop!.ipRating],
  ['Warranty', sop!.warranty],
] : isVsole ? [
  ['Series', vop!.series],
  ['Rated Power', `${vop!.powerKW} kW`],
  ['Phases', String(vop!.phases)],
  ...(vop!.batteryVoltage ? [['Battery Voltage', vop!.batteryVoltage] as [string, string]] : []),
  ['Max Efficiency', `${vop!.maxEfficiency}%`],
  ['MPPT Trackers', String(vop!.mpptCount)],
  ['Max PV Voltage', `${vop!.maxPvVoltage} V`],
  ...(vop!.maxChargeCurrentA ? [['Max Charge Current', `${vop!.maxChargeCurrentA} A`] as [string, string]] : []),
  ['AC Voltage', vop!.acVoltage],
  ['IP Rating', vop!.ipRating],
  ['Warranty', vop!.warranty],
] : isRenewSys ? [
  ['Model', rnp!.model],
  ['Power (STC)', `${rnp!.powerWp} Wp`],
  ['Cell Type', rnp!.cellType],
  ['Cell Configuration', rnp!.cellConfig],
  ['Module Efficiency', `${rnp!.moduleEfficiency}%`],
  ['Voc / Isc', `${rnp!.voc} V / ${rnp!.isc} A`],
  ['Vmp / Imp', `${rnp!.vmp} V / ${rnp!.imp} A`],
  ['Temp Coeff (Pmax)', rnp!.tempCoeffPmax],
  ['Bifacial', rnp!.bifacial ? `Yes (${rnp!.bifacialityFactor ?? '—'})` : 'No'],
  ['Glass Type', rnp!.glassType],
  ['Dimensions', rnp!.dimensions],
  ['Weight', `${rnp!.weight} kg`],
  ['Product Warranty', rnp!.productWarranty],
  ['Performance Warranty', rnp!.performanceWarranty],
] : isRayzon ? [
  ['Model', ryp!.model],
  ['Series', ryp!.series],
  ['Power (STC)', `${ryp!.powerWp} Wp`],
  ['Cell Type', ryp!.cellType],
  ['Cell Configuration', ryp!.cellConfig],
  ['Module Efficiency', `${ryp!.moduleEfficiency}%`],
  ['Voc / Isc', `${ryp!.voc} V / ${ryp!.isc} A`],
  ['Vmp / Imp', `${ryp!.vmp} V / ${ryp!.imp} A`],
  ['Temp Coeff (Pmax)', ryp!.tempCoeffPmax],
  ['Bifaciality', ryp!.bifacialityFactor],
  ['Glass Type', ryp!.glassType],
  ['Frame Thickness', ryp!.frameThickness],
  ['Product Warranty', ryp!.productWarranty],
  ['Performance Warranty', ryp!.performanceWarranty],
] : isLithiumValley ? [
  ['Series', lvp!.series],
  ['Module Capacity', `${lvp!.capacityKWh} kWh`],
  ['Max Stacked Capacity', `${lvp!.maxCapacityKWh} kWh`],
  ['Nominal Voltage', `${lvp!.nominalVoltage} V`],
  ['Capacity', `${lvp!.capacityAh} Ah`],
  ['Max Stack Layers', String(lvp!.maxStackLayers)],
  ['Max Charge / Discharge', `${lvp!.maxChargeCurrent} A / ${lvp!.maxDischargeCurrent} A`],
  ['Cycle Life', `${lvp!.cycleLife.toLocaleString()} @ ${lvp!.dod}% DoD`],
  ['IP Rating', lvp!.ipRating],
  ['Form Factor', lvp!.formFactor],
  ['Warranty', lvp!.warranty],
] : isBpl ? [
  ['Series', bpp!.series],
  ['Rated Power', `${bpp!.powerKW} kW`],
  ['Surge Power', `${bpp!.surgeKW} kW`],
  ['Battery Capacity', `${bpp!.batteryKWh} kWh`],
  ['Battery Voltage', `${bpp!.batteryVoltage} V`],
  ['Battery Capacity (Ah)', `${bpp!.batteryAh} Ah`],
  ['Cycle Life', `${bpp!.cycleLife.toLocaleString()} @ ${bpp!.dod}% DoD`],
  ['Max Efficiency', `${bpp!.maxEfficiency}%`],
  ['MPPT Voltage Range', bpp!.mpptVoltageRange],
  ['Max PV Input', `${bpp!.maxPvInputW} W`],
  ['AC Voltage', bpp!.acVoltage],
  ['IP Rating', bpp!.ipRating],
  ['Warranty', bpp!.warranty],
] : [];

const newBrandCerts: string[] = isSolinteg ? sop!.certifications
  : isRenewSys ? rnp!.certifications
  : isRayzon ? ryp!.certifications
  : isLithiumValley ? lvp!.certifications
  : isBpl ? bpp!.certifications
  : [];

// Schema.org
const schema = isDeye ? {
  "@context": "https://schema.org", "@type": "Product",
  "name": p.name, "description": p.seoDescription,
  "brand": { "@type": "Brand", "name": "Deye" },
  "offers": {
    "@type": "Offer", "priceCurrency": "INR",
    "price": p.sellingPrice.toFixed(2),
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  },
  "model": p.model,
} : isGoldi ? {
  "@context": "https://schema.org", "@type": "Product",
  "name": g.name, "description": g.seoDescription,
  "brand": { "@type": "Brand", "name": "Goldi Solar" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  },
  "model": g.model,
} : isHoymiles ? {
  "@context": "https://schema.org", "@type": "Product",
  "name": hp!.name, "description": hp!.seoDescription,
  "brand": { "@type": "Brand", "name": "Hoymiles" },
  "offers": {
    "@type": "Offer", "priceCurrency": "INR",
    "price": hp!.sellingPrice.toFixed(2),
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  },
  "model": hp!.model,
} : isTsun ? {
  "@context": "https://schema.org", "@type": "Product",
  "name": sp!.name, "description": sp!.seoDescription,
  "brand": { "@type": "Brand", "name": "TSUN" },
  "offers": {
    "@type": "Offer", "priceCurrency": "INR",
    "price": sp!.sellingPrice.toFixed(2),
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  },
  "model": sp!.model,
} : isNewBrand ? {
  "@context": "https://schema.org", "@type": "Product",
  "name": heroName, "description": heroDesc,
  "brand": { "@type": "Brand", "name": heroBrand },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  },
  "model": heroModel,
} : {
  "@context": "https://schema.org", "@type": "Product",
  "name": t.name, "description": t.seoDescription,
  "brand": { "@type": "Brand", "name": "Techedge" },
