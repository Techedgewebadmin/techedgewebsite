                  <p class="text-muted text-xs font-mono mb-2">{r.model}</p>
                  <p class="text-sm text-muted">{r.powerW} W · {r.maxEfficiency}% eff.</p>
                  <p class="text-lg font-bold mt-2" style="color:#06b6d4;">₹{r.sellingPrice.toLocaleString('en-IN')}</p>
