---
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import { deyeProducts, type DeyeProduct } from "@/data/deye-products";
import { allTechedgeProducts, type TechedgeProduct } from "@/data/techedge-products";
import { goldiProducts, type GoldiProduct } from "@/data/goldi-products";

export const prerender = true;

export const getStaticPaths = (() => {
  const deyePaths = deyeProducts.map(p => ({
    params: { slug: p.slug },
    props: { productType: 'deye' as const, product: p, teProduct: null, goldiProduct: null },
  }));
  const tePaths = allTechedgeProducts.map(p => ({
    params: { slug: p.slug },
    props: { productType: 'techedge' as const, product: null, teProduct: p, goldiProduct: null },
  }));
  const goldiPaths = goldiProducts.map(p => ({
    params: { slug: p.slug },
    props: { productType: 'goldi' as const, product: null, teProduct: null, goldiProduct: p },
  }));
  return [...deyePaths, ...tePaths, ...goldiPaths];
}) satisfies GetStaticPaths;

const { productType, product: dp, teProduct: tp, goldiProduct: gp } = Astro.props as {
  productType: 'deye' | 'techedge' | 'goldi';
  product: DeyeProduct | null;
  teProduct: TechedgeProduct | null;
  goldiProduct: GoldiProduct | null;
};

const isDeye = productType === 'deye';
const isGoldi = productType === 'goldi';
const p = dp!;
const t = tp!;
const g = gp!;

const formatPrice = (n: number) =>
  new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(n);

// ── DEYE helpers ──────────────────────────────────────────────────────────────
const catIcon: Record<string, string> = {
  'On-Grid': '⚡', 'Micro': '🔲', 'Hybrid': '🔋', 'Battery': '🏭', 'All-in-One': '📦',
};

const specLabels: Record<string, string> = {
  efficiency: 'Max Efficiency', ipRating: 'Protection Rating',
  mpptTrackers: 'MPPT Trackers', mpptVoltage: 'MPPT Voltage Range',
  maxInputVoltage: 'Max DC Input Voltage', batteryVoltage: 'Battery Voltage Range',
  dimensions: 'Dimensions (W×H×D)', weight: 'Weight', chemistry: 'Battery Chemistry',
  nominalCapacity: 'Nominal Capacity', nominalVoltage: 'Nominal Voltage', cycleLife: 'Cycle Life',
  usableEnergy: 'Usable Energy', systemNominalVoltage: 'System Voltage',
  moduleEnergy: 'Module Energy', moduleVoltage: 'Module Voltage',
  moduleCapacity: 'Module Capacity', modulesInSystem: 'Modules in System',
  chargeCurrentRecommended: 'Charge Current (Rec.)', chargeCurrentMax: 'Charge Current (Max)',
  recommendedDoD: 'Recommended DoD', operatingTempDischarge: 'Operating Temp (Discharge)',
  operatingTempCharge: 'Operating Temp (Charge)', storageTemp: 'Storage Temperature',
  thermalManagement: 'Thermal Management', systemWeight: 'System Weight',
  communication: 'Communication', display: 'Display', altitude: 'Max Altitude',
  humidity: 'Humidity', certification: 'Certification',
  ratedAcPower: 'Rated AC Power', maxApparentPower: 'Max Apparent Power',
  acVoltage: 'AC Voltage', gridFrequency: 'Grid Frequency',
  powerFactor: 'Power Factor', thd: 'THD', cooling: 'Cooling',
  topology: 'Topology', scalability: 'Scalability', peakPowerSupport: 'Peak Power Support',
  euroEfficiency: 'Euro Efficiency', batteryVoltageRange: 'Battery Voltage Range',
  maxChargeCurrent: 'Max Charge Current', maxDischargeCurrent: 'Max Discharge Current',
  operatingTemp: 'Operating Temperature',
};

const deyeHasSpecs = isDeye && Object.keys(p.specs).length > 0 && Object.values(p.specs).some(v => v !== undefined);
const related = isDeye
  ? deyeProducts.filter(r => r.category === p.category && r.id !== p.id).slice(0, 4)
  : isGoldi
    ? goldiProducts.filter(r => r.id !== g.id).slice(0, 4)
    : allTechedgeProducts.filter(r => r.category === t.category && r.id !== t.id).slice(0, 4);
const priceWithGst = isDeye ? Math.round(p.sellingPrice * (1 + p.gstRate / 100)) : 0;

// ── HERO SLIDE DATA (unified across all three brands) ─────────────────────────
const heroName  = isDeye ? dp!.name  : isGoldi ? gp!.name  : tp!.name;
const heroModel = isDeye ? dp!.model : isGoldi ? gp!.model : tp!.model;
const heroBrand = isDeye ? 'Deye'    : isGoldi ? 'Goldi Solar' : 'Techedge';
const heroBrandColor = isDeye ? '#f97316' : isGoldi ? '#eab308' : '#86efac';

const heroStats: { value: string; label: string }[] = isDeye ? [
  ...(dp!.specs.efficiency ? [{ value: dp!.specs.efficiency, label: 'Max Efficiency' }] : []),
  ...(dp!.specs.ipRating   ? [{ value: dp!.specs.ipRating,   label: 'IP Rating' }]      : []),
  ...(dp!.specs.mpptTrackers ? [{ value: String(dp!.specs.mpptTrackers), label: 'MPPT Trackers' }] : []),
  { value: dp!.warranty, label: 'Warranty' },
].slice(0, 4) : isGoldi ? [
  { value: `${gp!.efficiency}%`,         label: 'Efficiency' },
  { value: `${gp!.powerWp} Wp`,          label: 'Power (STC)' },
  { value: gp!.performanceWarranty,       label: 'Performance' },
  { value: gp!.productWarranty,           label: 'Product Warranty' },
] : [
  { value: `${tp!.backupHours} hrs`,      label: 'Backup Time' },
  { value: tp!.batterySpec,               label: 'Battery' },
  { value: tp!.panelSpec,                 label: 'Solar Panel' },
  ...(tp!.loadSpec ? [{ value: tp!.loadSpec, label: 'Load' }] : []),
].slice(0, 4);

const heroFeatures = (isDeye ? dp!.features : isGoldi ? gp!.features : tp!.features).slice(0, 3);
const heroUseCases = isDeye ? dp!.useCases  : isGoldi ? gp!.useCases  : tp!.useCases;
const heroDesc     = isDeye ? dp!.seoDescription : isGoldi ? gp!.seoDescription : tp!.seoDescription;

// Schema.org
const schema = isDeye ? {
  "@context": "https://schema.org", "@type": "Product",
  "name": p.name, "description": p.seoDescription,
  "brand": { "@type": "Brand", "name": "Deye" },
  "offers": {
    "@type": "Offer", "priceCurrency": "INR",
    "price": p.sellingPrice.toFixed(2),
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  },
  "model": p.model,
} : isGoldi ? {
  "@context": "https://schema.org", "@type": "Product",
  "name": g.name, "description": g.seoDescription,
  "brand": { "@type": "Brand", "name": "Goldi Solar" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  },
  "model": g.model,
} : {
  "@context": "https://schema.org", "@type": "Product",
  "name": t.name, "description": t.seoDescription,
  "brand": { "@type": "Brand", "name": "Techedge" },
  "offers": t.moqPricing.map(tier => ({
    "@type": "Offer", "priceCurrency": "INR",
    "price": tier.price.toFixed(2),
    "description": `MOQ ${tier.moq} units`,
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Techedge India" }
  })),
  "model": t.model,
};
---

<Layout
  title={isDeye ? p.seoTitle : isGoldi ? g.seoTitle : t.seoTitle}
  description={isDeye ? p.seoDescription : isGoldi ? g.seoDescription : t.seoDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Breadcrumb -->
  <div class="pt-28 pb-0 px-4 bg-background-foreground">
    <div class="max-w-7xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-muted font-semibold">
        <a href="/" class="hover:text-secondary transition-colors">Home</a>
        <span>/</span>
        <a href="/products/" class="hover:text-secondary transition-colors">Products</a>
        <span>/</span>
        {isDeye && <><a href="/products/deye/" class="hover:text-secondary transition-colors">Deye</a><span>/</span></>}
        {isGoldi && <><a href="/products/goldi/" class="hover:text-secondary transition-colors">Goldi Solar</a><span>/</span></>}
        {!isDeye && !isGoldi && <><a href="/products/techedge/" class="hover:text-secondary transition-colors">Techedge</a><span>/</span></>}
        <span class="text-foreground">{isDeye ? p.name : isGoldi ? g.name : t.name}</span>
      </nav>
    </div>
  </div>

  <!-- ── ROTATING PRODUCT HERO ─────────────────────────────────────────────── -->
  <div class="relative overflow-hidden" style="background:#0a1628; min-height:360px;">
    <!-- Ambient glow -->
    <div class="absolute inset-0 pointer-events-none" style={`background: radial-gradient(ellipse at 75% 40%, ${heroBrandColor}18 0%, transparent 60%)`}></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 lg:px-8">

      <!-- ── SLIDE 1: Identity ─────────────── -->
      <div class="hero-slide py-12 lg:py-16" data-slide="0">
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full" style={`color:${heroBrandColor}; background:${heroBrandColor}18; border:1px solid ${heroBrandColor}40`}>
            {heroBrand}
          </span>
          {isDeye && <span class="text-xs font-semibold uppercase text-white/50 bg-white/5 px-3 py-1 rounded-full border border-white/10">{dp!.category}</span>}
          {isGoldi && <span class="text-xs font-semibold uppercase text-white/50 bg-white/5 px-3 py-1 rounded-full border border-white/10">{gp!.series}</span>}
          {!isDeye && !isGoldi && <span class="text-xs font-semibold uppercase text-white/50 bg-white/5 px-3 py-1 rounded-full border border-white/10">{tp!.category}</span>}
        </div>
        <h1 class="font-anton text-4xl md:text-6xl lg:text-7xl uppercase text-white leading-none mb-2">
          {heroName}
        </h1>
        <p class="font-mono text-sm text-white/40 mb-8">Model: {heroModel}</p>
        <div class="flex flex-wrap gap-4">
          {heroStats.map(s => (
            <div class="rounded-2xl px-5 py-3 text-center" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1);">
              <p class="text-2xl font-bold" style={`color:${heroBrandColor}`}>{s.value}</p>
              <p class="text-[10px] uppercase tracking-wider text-white/40 font-semibold mt-0.5">{s.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- ── SLIDE 2: Features ─────────────── -->
      <div class="hero-slide py-12 lg:py-16 hidden" data-slide="1">
        <p class="text-xs font-bold uppercase tracking-widest mb-6" style={`color:${heroBrandColor}`}>Key Features</p>
        <div class="space-y-5">
          {heroFeatures.map((f, i) => (
            <div class="flex items-start gap-4">
              <span class="text-xl font-bold shrink-0 mt-0.5" style={`color:${heroBrandColor}`}>0{i + 1}</span>
              <p class="text-white/90 text-lg md:text-xl font-light leading-snug">{f}</p>
            </div>
          ))}
        </div>
        <p class="text-white/30 text-xs mt-8 font-mono">{heroModel}</p>
      </div>

      <!-- ── SLIDE 3: Applications ─────────── -->
      <div class="hero-slide py-12 lg:py-16 hidden" data-slide="2">
        <p class="text-xs font-bold uppercase tracking-widest mb-6" style={`color:${heroBrandColor}`}>Ideal For</p>
        <div class="flex flex-wrap gap-3 mb-8">
          {heroUseCases.map(uc => (
            <span class="text-sm font-semibold px-4 py-2 rounded-full text-white/80" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12);">
              {uc}
            </span>
          ))}
        </div>
        <p class="text-white/40 text-sm max-w-2xl leading-relaxed">{heroDesc.slice(0, 160)}…</p>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="absolute bottom-0 left-0 h-[2px] w-full" style="background:rgba(255,255,255,0.08)">
      <div id="phero-bar" class="h-full" style={`background:${heroBrandColor}; width:0%`}></div>
    </div>

    <!-- Dot nav -->
    <div class="absolute bottom-5 right-6 flex items-center gap-2">
      {[0,1,2].map(i => (
        <button class="phero-dot transition-all duration-300 rounded-full" data-target={i}
          style={i === 0 ? `width:20px; height:4px; background:${heroBrandColor}` : 'width:8px; height:4px; background:rgba(255,255,255,0.25)'}
          aria-label={`Slide ${i+1}`}
        ></button>
      ))}
    </div>
  </div>

  <script define:vars={{ heroBrandColor }}>
    const slides   = document.querySelectorAll('.hero-slide');
    const dots     = document.querySelectorAll('.phero-dot');
    const bar      = document.getElementById('phero-bar');
    const DURATION = 5500;
    let current = 0;
    let timer, barTween;

    function startBar() {
      if (!bar) return;
      bar.style.transition = 'none';
      bar.style.width = '0%';
      requestAnimationFrame(() => {
        bar.style.transition = `width ${DURATION}ms linear`;
        bar.style.width = '100%';
      });
    }

    function goTo(idx) {
      // Hide current
      slides[current].style.opacity = '0';
      slides[current].style.transform = 'translateY(-16px)';
      setTimeout(() => {
        slides[current].classList.add('hidden');
        slides[current].style.opacity = '';
        slides[current].style.transform = '';
        current = idx;
        slides[current].classList.remove('hidden');
        slides[current].style.opacity = '0';
        slides[current].style.transform = 'translateY(16px)';
        requestAnimationFrame(() => {
          slides[current].style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          slides[current].style.opacity = '1';
          slides[current].style.transform = 'translateY(0)';
          setTimeout(() => { slides[current].style.transition = ''; }, 520);
        });
      }, 350);

      // Update dots
      dots.forEach((d, i) => {
        if (i === idx) {
          d.style.width = '20px';
          d.style.height = '4px';
          d.style.background = heroBrandColor;
        } else {
          d.style.width = '8px';
          d.style.height = '4px';
          d.style.background = 'rgba(255,255,255,0.25)';
        }
      });

      startBar();
    }

    function next() {
      goTo((current + 1) % slides.length);
      clearTimeout(timer);
      timer = setTimeout(next, DURATION);
    }

    // Boot
    startBar();
    timer = setTimeout(next, DURATION);

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        clearTimeout(timer);
        goTo(i);
        timer = setTimeout(next, DURATION);
      });
    });
  </script>

  <!-- ── DEYE PRODUCT LAYOUT ─────────────────────────────────────────────── -->
  {isDeye && (
    <>
      <section class="py-10 px-4 bg-background-foreground">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
          <div class="lg:col-span-7">
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="text-sm font-bold uppercase tracking-widest text-secondary">
                {catIcon[p.category]} {p.category}
              </span>
              <span class="text-xs font-semibold uppercase text-muted bg-muted-foreground/10 px-3 py-1 rounded-full">
                {p.subcategory}
              </span>
              {p.phase && p.phase !== 'N/A' && (
                <span class="text-xs font-semibold uppercase text-muted bg-muted-foreground/10 px-3 py-1 rounded-full">
                  {p.phase}
                </span>
              )}
            </div>
            <h1 class="font-anton text-3xl md:text-5xl uppercase text-foreground leading-none mb-3">
              {p.name}
            </h1>
            <p class="font-mono text-sm text-muted mb-6">
              Model: <span class="text-foreground font-semibold">{p.model}</span>
            </p>
            <div class="flex flex-wrap gap-3 mb-8">
              {p.specs.efficiency && (
                <div class="bg-secondary/10 border border-secondary/30 rounded-xl px-4 py-2 text-center">
                  <p class="text-xl font-bold text-secondary">{p.specs.efficiency}</p>
                  <p class="text-[10px] uppercase text-muted font-semibold">Max Efficiency</p>
                </div>
              )}
              {p.specs.ipRating && (
                <div class="bg-muted-foreground/10 rounded-xl px-4 py-2 text-center">
                  <p class="text-xl font-bold text-foreground">{p.specs.ipRating}</p>
                  <p class="text-[10px] uppercase text-muted font-semibold">Protection</p>
                </div>
              )}
              {p.warranty && (
                <div class="bg-muted-foreground/10 rounded-xl px-4 py-2 text-center">
                  <p class="text-xl font-bold text-foreground">{p.warranty}</p>
                  <p class="text-[10px] uppercase text-muted font-semibold">Warranty</p>
                </div>
              )}
              {p.specs.mpptTrackers && (
                <div class="bg-muted-foreground/10 rounded-xl px-4 py-2 text-center">
                  <p class="text-xl font-bold text-foreground">{p.specs.mpptTrackers}</p>
                  <p class="text-[10px] uppercase text-muted font-semibold">MPPT Trackers</p>
                </div>
              )}
              {p.specs.cycleLife && (
                <div class="bg-muted-foreground/10 rounded-xl px-4 py-2 text-center">
                  <p class="text-base font-bold text-foreground">{p.specs.cycleLife}</p>
                  <p class="text-[10px] uppercase text-muted font-semibold">Cycle Life</p>
                </div>
              )}
            </div>
            <p class="text-muted leading-relaxed mb-8">{p.seoDescription}</p>
            <div class="mb-8">
              <h2 class="font-grotesk font-bold text-foreground text-lg mb-4 uppercase tracking-wide">Key Features</h2>
              <ul class="space-y-2">
                {p.features.map(f => (
                  <li class="flex items-start gap-3 text-sm text-muted">
                    <span class="text-secondary font-bold mt-0.5 shrink-0">✓</span>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <h2 class="font-grotesk font-bold text-foreground text-lg mb-4 uppercase tracking-wide">Ideal For</h2>
              <div class="flex flex-wrap gap-2">
                {p.useCases.map(uc => (
                  <span class="text-xs bg-muted-foreground/10 border border-muted/20 px-3 py-1.5 rounded-full text-muted">{uc}</span>
                ))}
              </div>
            </div>
          </div>

          <div class="lg:col-span-5">
            <div class="lg:sticky lg:top-24 space-y-5">
              <div class="bg-muted-foreground/5 border-2 border-secondary/30 rounded-2xl p-6">
                <p class="text-xs uppercase font-bold text-muted tracking-widest mb-1">Our Selling Price</p>
                <p class="text-4xl font-grotesk font-bold text-secondary mb-1">{formatPrice(p.sellingPrice)}</p>
                <p class="text-xs text-muted mb-4">excl. {p.gstRate}% GST</p>
                <div class="bg-muted-foreground/10 rounded-xl px-4 py-3 mb-5">
                  <div class="flex justify-between text-sm">
                    <span class="text-muted">Price excl. GST</span>
                    <span class="text-foreground font-semibold">{formatPrice(p.sellingPrice)}</span>
                  </div>
                  <div class="flex justify-between text-sm mt-1">
                    <span class="text-muted">GST ({p.gstRate}%)</span>
                    <span class="text-foreground font-semibold">{formatPrice(Math.round(p.sellingPrice * p.gstRate / 100))}</span>
                  </div>
                  <div class="flex justify-between text-sm font-bold mt-2 pt-2 border-t border-muted/20">
                    <span class="text-foreground">Total (incl. GST)</span>
                    <span class="text-secondary">{formatPrice(priceWithGst)}</span>
                  </div>
                </div>
                <div class="space-y-2 text-xs text-muted mb-5">
                  <p>✓ Authorised dealer pricing</p>
                  <p>✓ Transport charges extra (at actuals)</p>
                  <p>✓ Installation charges extra</p>
                  <p>✓ Prices valid April 2026</p>
                </div>
                <a href="/contact" class="block w-full bg-secondary text-black font-anton text-lg uppercase text-center py-4 rounded-xl hover:bg-secondary/90 transition-colors mb-3">
                  Get a Quote
                </a>
                <a href="tel:+919876543210" class="block w-full bg-muted-foreground/10 text-foreground font-grotesk font-semibold text-sm text-center py-3 rounded-xl hover:bg-muted-foreground/20 transition-colors border border-muted/20">
                  📞 Call for Bulk Pricing
                </a>
              </div>

              {deyeHasSpecs && (
                <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-6">
                  <h3 class="font-grotesk font-bold text-foreground uppercase tracking-wide mb-4">Technical Specifications</h3>
                  <dl class="space-y-3">
                    {Object.entries(p.specs).map(([key, val]) => val ? (
                      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-0.5 pb-3 border-b border-muted/10 last:border-0 last:pb-0">
                        <dt class="text-xs uppercase text-muted font-semibold tracking-wide">{specLabels[key] ?? key}</dt>
                        <dd class="text-sm font-semibold text-foreground sm:text-right">{String(val)}</dd>
                      </div>
                    ) : null)}
                    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-0.5 pb-3 border-b border-muted/10 last:border-0 last:pb-0">
                      <dt class="text-xs uppercase text-muted font-semibold tracking-wide">Warranty</dt>
                      <dd class="text-sm font-semibold text-foreground sm:text-right">{p.warranty}</dd>
                    </div>
                  </dl>
                </div>
              )}
              <p class="text-xs text-muted text-center">
                Specifications sourced from <a href="https://www.deyeinverter.com" target="_blank" rel="noopener" class="text-secondary hover:underline">deyeinverter.com</a>
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-8 px-4 bg-muted-foreground/5 border-t border-muted/10">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-4 text-sm text-muted">
          <div class="flex gap-3"><span class="text-xl">🛡️</span><div><p class="font-bold text-foreground mb-1">Warranty</p><p>On-grid ≤10 kW: 10 yrs | &gt;10 kW: 8 yrs | Hybrid: 5 yrs | LiFePO4: 10 yrs</p></div></div>
          <div class="flex gap-3"><span class="text-xl">🧾</span><div><p class="font-bold text-foreground mb-1">GST Rates</p><p>Solar inverters: 5% GST | Batteries, accessories & ESS systems: 18% GST</p></div></div>
          <div class="flex gap-3"><span class="text-xl">📦</span><div><p class="font-bold text-foreground mb-1">Supply & Installation</p><p>Transport at actuals. Installation by Techedge-certified engineers extra.</p></div></div>
        </div>
      </section>
    </>
  )}

  <!-- ── TECHEDGE PRODUCT LAYOUT ─────────────────────────────────────────── -->
  {!isDeye && !isGoldi && (
    <>
      <section class="py-10 px-4 bg-background-foreground">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">

          <!-- Left: Product info -->
          <div class="lg:col-span-7">
            <div class="flex flex-wrap items-center gap-2 mb-4">
