                  <span class="text-xs font-semibold px-3 py-1.5 rounded-lg" style={c.includes('BIS') ? 'background:rgba(239,68,68,0.1); color:#ef4444; border:1px solid rgba(239,68,68,0.2);' : 'background:rgba(255,255,255,0.05); color:#94a3b8;'}>{c}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="py-10 px-4">
        <div class="max-w-7xl mx-auto">
          <h2 class="font-anton text-2xl md:text-3xl uppercase text-foreground mb-6">Ideal For</h2>
          <div class="flex flex-wrap gap-3">
            {sp!.useCases.map(uc => (
              <span class="text-sm font-semibold px-4 py-2 rounded-full text-muted bg-muted-foreground/5 border border-muted/20">{uc}</span>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  <!-- ── NEW BRAND PRODUCT LAYOUT (Solinteg / Vsole / RenewSys / Rayzon / Lithium Valley / BPL PowerZen) ──────── -->
