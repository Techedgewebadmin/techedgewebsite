---
import Layout from "@/layouts/Layout.astro";
import { rayzonProducts } from "@/data/rayzon-products";

const color = '#64748b';
const colorAccent = '#94a3b8';
const colorLight = 'rgba(100,116,139,0.10)';
const colorBorder = 'rgba(100,116,139,0.22)';
---

<Layout
  title="Rayzon TOPCon Solar Panels India | ALMM Listed | 30-Year Warranty | Techedge"
  description="Rayzon 210R TOPCon N-type bifacial solar panels — 615–625 Wp, 22.97% efficiency, BIS certified, ALMM listed, UL certified. 15-year product + 30-year performance warranty. Supply by Techedge Bengaluru."
  keywords="Rayzon solar panel India, Rayzon TOPCon panel, ALMM solar panel India, solar panel Bengaluru, bifacial panel India"
>

  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 border-b border-muted/10" style={`background:linear-gradient(135deg,#0a0a12 60%,${colorLight})`}>
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-6">
        <a href="/products/" class="text-muted text-sm hover:text-white">Products</a>
        <span class="text-muted/40">›</span>
        <span style={`color:${colorAccent}`} class="text-sm font-semibold">Rayzon</span>
      </div>
      <div class="flex flex-wrap items-start gap-4 mb-4">
        <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full border" style={`color:${colorAccent};border-color:${colorBorder};background:${colorLight}`}>Made in India</span>
        <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full border" style={`color:${colorAccent};border-color:${colorBorder};background:${colorLight}`}>ALMM Listed</span>
        <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full border" style={`color:${colorAccent};border-color:${colorBorder};background:${colorLight}`}>BIS IS 14286</span>
        <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full border" style={`color:${colorAccent};border-color:${colorBorder};background:${colorLight}`}>UL Certified</span>
      </div>
      <h1 class="font-anton text-5xl md:text-7xl uppercase text-white leading-none mb-4">Rayzon</h1>
      <p class="text-muted text-lg max-w-2xl mb-8">
        210R series N-type TOPCon bifacial solar panels — 615–625 Wp, glass-to-glass construction, 16 busbar cells.
        ALMM listed, BIS and UL certified. 15-year product warranty, 30-year linear performance.
      </p>
      <div class="flex flex-wrap gap-3">
        {[
          ['615–625 Wp', 'Power Range'],
          ['22.97%', 'Peak Efficiency'],
          ['15 Years', 'Product Warranty'],
          ['30 Years', 'Performance Warranty'],
          ['ALMM Listed', 'Subsidy Eligible'],
        ].map(([v, l]) => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-xl px-5 py-3">
            <p class="text-xl font-grotesk font-bold text-white">{v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Spec Table -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-2">210R TOPCon — Model Range</h2>
      <p class="text-muted text-sm mb-8">132 half-cut cells · 16BB · N-type TOPCon · Bifacial glass-glass · 11.9 mm frame</p>
      <div class="overflow-x-auto rounded-2xl border border-muted/10">
        <table class="w-full text-sm">
          <thead>
            <tr style={`background:${colorLight}`}>
              {['Model','Power','Efficiency','Isc','Voc','Imp','Vmp','Bifaciality','Product W','Performance W'].map(h => (
                <th class="text-left px-4 py-3 text-xs font-bold uppercase tracking-wider text-foreground">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {rayzonProducts.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-muted-foreground/5' : 'bg-transparent'}>
                <td class="px-4 py-3 font-semibold text-foreground">{p.model}</td>
                <td class="px-4 py-3 font-bold" style={`color:${colorAccent}`}>{p.powerWp} Wp</td>
                <td class="px-4 py-3 text-muted">{p.moduleEfficiency}%</td>
                <td class="px-4 py-3 text-muted">{p.isc} A</td>
                <td class="px-4 py-3 text-muted">{p.voc} V</td>
                <td class="px-4 py-3 text-muted">{p.imp} A</td>
                <td class="px-4 py-3 text-muted">{p.vmp} V</td>
                <td class="px-4 py-3 text-muted">{p.bifacialityFactor}</td>
                <td class="px-4 py-3 text-muted">{p.productWarranty}</td>
                <td class="px-4 py-3 text-muted">{p.performanceWarranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-muted text-xs mt-3">All specs at STC (1000 W/m², 25°C, AM 1.5). Temp coefficient Pmax: -0.28%/°C.</p>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-8">Certifications & Compliance</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
        {[
          ['BIS IS 14286', 'Indian Standards — DISCOM net metering compliance'],
          ['IEC 61215', 'Module design qualification and type approval'],
          ['IEC 61730', 'Safety qualification'],
          ['UL 61215', 'US market safety standard'],
          ['ALMM Listed', 'MNRE approved list — subsidy projects'],
          ['ISO 9001:2015', 'Quality management'],
          ['ISO 14001:2015', 'Environmental management'],
          ['ISO 45001:2018', 'Occupational safety'],
        ].map(([cert, desc]) => (
          <div class="rounded-xl border p-4" style={`background:${colorLight};border-color:${colorBorder}`}>
            <p class="font-bold text-foreground text-sm mb-1">{cert}</p>
            <p class="text-muted text-xs">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-4">Enquire About Rayzon Panels</h2>
      <p class="text-muted mb-8">EPC supply and installation across Bengaluru and Karnataka.</p>
      <a href="/contact" class="inline-block font-anton text-lg uppercase px-8 py-4 rounded-xl border border-muted/30 hover:bg-muted-foreground/10 transition-colors text-foreground">
        Get a Quote →
      </a>
    </div>
  </section>

</Layout>
