---
import Layout from "@/layouts/Layout.astro";
import { hoymilesProducts, hoymilesSeriesMeta } from "@/data/hoymiles-products";

const hmProducts  = hoymilesProducts.filter(p => p.series === 'HM');
const hmsProducts = hoymilesProducts.filter(p => p.series === 'HMS');

const minPower = Math.min(...hoymilesProducts.map(p => p.powerW));
const maxPower = Math.max(...hoymilesProducts.map(p => p.powerW));
---

<Layout
  title="Hoymiles Micro Inverters India — HM & HMS Series 300W–2000W | Techedge"
  description="Buy Hoymiles micro inverters (HM & HMS series, 300W–2000W) in India. Per-panel MPPT, IP67, up to 97% efficiency, 12–15 year warranty. Authorised dealer & installation — Techedge India, Bengaluru."
  keywords="Hoymiles micro inverter India, HM-600 price India, HMS-800W-T2 India, micro inverter authorised dealer Bengaluru, per panel MPPT inverter India"
>

  <!-- Breadcrumb -->
  <div class="pt-28 pb-0 px-4 bg-background-foreground">
    <div class="max-w-7xl mx-auto">
      <nav class="flex items-center gap-2 text-xs text-muted font-semibold">
        <a href="/" class="hover:text-cyan-400 transition-colors">Home</a>
        <span>/</span>
        <a href="/products/" class="hover:text-cyan-400 transition-colors">Products</a>
        <span>/</span>
        <span class="text-foreground">Hoymiles</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-background-foreground pt-8 pb-14 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-cyan-400 text-xs font-bold uppercase tracking-widest">Hoymiles — Authorised Dealer</span>
      </div>
      <h1 class="font-anton text-4xl md:text-6xl xl:text-7xl uppercase text-foreground leading-none mb-4">
        Hoymiles<br />
        <span class="text-cyan-400">Micro Inverters</span>
      </h1>
      <p class="text-muted text-lg max-w-2xl mb-8">
        Per-panel MPPT micro inverters — HM Series (300–2000 W) and HMS Series (800–2000 W).
        IP67 rated, up to 97% efficiency, 12–15 year warranty. Supply and installation by Techedge.
      </p>

      <!-- Stats -->
      <div class="flex flex-wrap gap-4 mb-8">
        {[
          { v: String(hoymilesProducts.length), l: 'Products' },
          { v: `${minPower}W–${maxPower}W`, l: 'Power Range' },
          { v: '12–15 Yrs', l: 'Warranty' },
          { v: 'IP67', l: 'Protection Rating' },
        ].map(s => (
          <div class="bg-muted-foreground/10 rounded-xl px-5 py-3 border border-muted/20">
            <p class="text-xl font-grotesk font-bold text-foreground">{s.v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{s.l}</p>
          </div>
        ))}
      </div>

      <!-- Key advantages -->
      <div class="flex flex-wrap gap-2">
        {[
          '🔲 Per-Panel MPPT',
          '💧 IP67 Weatherproof',
          '📱 S-Miles Cloud App',
          '🌑 Shade Resilient',
          '🔌 Plug-and-Play AC',
          '🔇 Silent — No Fans',
          '⚡ Up to 97% Efficiency',
          '🛡️ Up to 15-Year Warranty',
        ].map(t => (
          <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-muted-foreground/10 border border-muted/20 text-foreground">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- HM Series -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <div class="mb-10">
        <span class="text-cyan-400 text-xs font-bold uppercase tracking-widest">{hoymilesSeriesMeta.HM.label}</span>
        <h2 class="font-anton text-2xl md:text-3xl uppercase text-foreground mt-1 mb-2">HM Series — 300 W to 2000 W</h2>
        <p class="text-muted max-w-2xl text-sm">
          {hoymilesSeriesMeta.HM.description}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        {hmProducts.map(p => (
          <a
            href={`/products/${p.slug}/`}
            class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border border-muted/20 hover:border-cyan-400/40 rounded-2xl p-5 transition-all duration-200 flex flex-col"
          >
            <span class="text-[10px] font-bold uppercase tracking-widest text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded-full mb-3 self-start">
              {p.series} Series
            </span>

            <h3 class="font-anton text-2xl text-cyan-400 mb-1">{p.powerW} W</h3>
            <p class="font-mono text-xs text-muted mb-4">{p.model}</p>

            <div class="space-y-1.5 flex-1">
              <p class="text-xs text-muted">⚡ Max efficiency: <span class="text-foreground font-semibold">{p.maxEfficiency}%</span></p>
              <p class="text-xs text-muted">🔲 PV inputs: <span class="text-foreground font-semibold">{p.pvInputs}</span></p>
              <p class="text-xs text-muted">💧 IP rating: <span class="text-foreground font-semibold">{p.ipRating}</span></p>
              <p class="text-xs text-muted">🛡️ Warranty: <span class="text-foreground font-semibold">{p.warranty}</span></p>
              <p class="text-xs text-muted">🌡️ Op. temp: <span class="text-foreground font-semibold">{p.operatingTemp}</span></p>
            </div>

            <div class="mt-4 pt-4 border-t border-muted/20">
              <p class="text-[10px] uppercase text-muted font-semibold mb-1">Indicative Price</p>
              <p class="text-sm font-bold text-foreground">₹{p.sellingPrice.toLocaleString('en-IN')}</p>
              <p class="text-[10px] text-muted">+ 12% GST · excl. DTU</p>
            </div>

            <div class="mt-3 flex items-center gap-1 text-cyan-400 text-xs font-semibold">
              <span>Contact for Quote</span>
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HMS Series -->
  <section class="py-16 px-4 border-b border-muted/10 bg-muted-foreground/3">
    <div class="max-w-7xl mx-auto">
      <div class="mb-10">
        <span class="text-cyan-400 text-xs font-bold uppercase tracking-widest">{hoymilesSeriesMeta.HMS.label}</span>
        <h2 class="font-anton text-2xl md:text-3xl uppercase text-foreground mt-1 mb-2">HMS Series — 800 W to 2000 W</h2>
        <p class="text-muted max-w-2xl text-sm">
          {hoymilesSeriesMeta.HMS.description}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {hmsProducts.map(p => (
          <a
            href={`/products/${p.slug}/`}
            class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border border-muted/20 hover:border-cyan-400/40 rounded-2xl p-5 transition-all duration-200 flex flex-col"
          >
            <span class="text-[10px] font-bold uppercase tracking-widest text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded-full mb-3 self-start">
              {p.series} Series
            </span>

            <h3 class="font-anton text-2xl text-cyan-400 mb-1">{p.powerW} W</h3>
            <p class="font-mono text-xs text-muted mb-4">{p.model}</p>

            <div class="space-y-1.5 flex-1">
              <p class="text-xs text-muted">⚡ Max efficiency: <span class="text-foreground font-semibold">{p.maxEfficiency}%</span></p>
              <p class="text-xs text-muted">🌍 EU efficiency: <span class="text-foreground font-semibold">{p.euEfficiency}%</span></p>
              <p class="text-xs text-muted">🔲 PV inputs: <span class="text-foreground font-semibold">{p.pvInputs}</span></p>
              <p class="text-xs text-muted">💧 IP rating: <span class="text-foreground font-semibold">{p.ipRating}</span></p>
              <p class="text-xs text-muted">🛡️ Warranty: <span class="text-foreground font-semibold">{p.warranty}</span></p>
            </div>

            <div class="mt-4 pt-4 border-t border-muted/20">
              <p class="text-[10px] uppercase text-muted font-semibold mb-1">Indicative Price</p>
              <p class="text-sm font-bold text-foreground">₹{p.sellingPrice.toLocaleString('en-IN')}</p>
              <p class="text-[10px] text-muted">+ 12% GST · excl. DTU</p>
            </div>

            <div class="mt-3 flex items-center gap-1 text-cyan-400 text-xs font-semibold">
              <span>Contact for Quote</span>
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Micro Inverters -->
  <section class="py-16 px-4 bg-muted-foreground/3 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-cyan-400 text-xs font-bold uppercase tracking-widest">Technology</span>
        <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mt-2">Why Micro Inverters Win</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            icon: '🔲',
            title: 'Per-Panel MPPT',
            body: 'Each panel has its own maximum power point tracking. One shaded or dirty panel does not drag down the output of the entire array — unlike string inverters.',
          },
          {
            icon: '📊',
            title: 'Module-Level Monitoring',
            body: 'Hoymiles DTU and S-Miles Cloud app provide real-time per-panel data — identify underperforming panels instantly without on-site visits.',
          },
          {
            icon: '🌧️',
            title: 'Perfect for Indian Rooftops',
            body: 'Mixed panel orientations, partial shading from water tanks, trees or neighbouring buildings — micro inverters eliminate these yield losses completely.',
          },
          {
            icon: '🔌',
            title: 'Plug-and-Play Installation',
            body: 'AC bus wiring is simpler and safer than DC string wiring. Faster installation, lower labour cost, and no high-voltage DC on the roof.',
          },
          {
            icon: '📈',
            title: 'Modular Expansion',
            body: 'Add panels one at a time without redesigning the system. Micro inverters scale linearly — ideal for phased installations and future expansion.',
          },
          {
            icon: '🛡️',
            title: '12–15 Year Warranty',
            body: 'HM Series includes a 12-year product warranty. HMS Series extends this to 15 years — backed by Hoymiles global support and Techedge local service.',
          },
        ].map(f => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-2xl p-6">
            <span class="text-3xl mb-4 block">{f.icon}</span>
            <h3 class="font-bold text-foreground mb-2">{f.title}</h3>
            <p class="text-muted text-sm leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-12 px-4 bg-muted-foreground/3 border-b border-muted/10">
    <div class="max-w-5xl mx-auto text-center">
      <span class="text-cyan-400 text-xs font-bold uppercase tracking-widest">Certifications</span>
      <h2 class="font-anton text-2xl uppercase text-foreground mt-2 mb-6">International Standards</h2>
      <div class="flex flex-wrap justify-center gap-2">
        {['IEC 62109-1/2', 'VDE0126', 'EN50438', 'CEI0-21', 'G83/G98', 'AS4777'].map(c => (
          <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-muted-foreground/5 border border-muted/20 text-muted">{c}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-cyan-400/5">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mb-4">
        Get a Quote for Hoymiles Micro Inverters
      </h2>
      <p class="text-muted mb-8">
        Contact Techedge for current pricing, system design and installation.
        We supply pan-India and install across Karnataka and South India.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-cyan-400 text-black font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-cyan-300 transition-colors">
          Get a Project Quote
        </a>
        <a href="/solutions/" class="bg-muted-foreground/10 text-foreground font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-muted-foreground/20 transition-colors border border-muted/30">
          View Solar Solutions
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-xs text-muted">
        {['🏅 Hoymiles Authorised Dealer', '⚡ Design & Installation', '🌍 Supply Pan-India', '🧾 12% GST on Micro Inverters'].map(t => <span>{t}</span>)}
      </div>
    </div>
  </section>

</Layout>
