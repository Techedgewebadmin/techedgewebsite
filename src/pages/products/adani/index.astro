---
import Layout from "@/layouts/Layout.astro";
import { adaniProducts } from "@/data/adani-products";

const color = '#7c3aed';
const colorAccent = '#a78bfa';
const colorLight = 'rgba(124,58,237,0.10)';
const colorBorder = 'rgba(124,58,237,0.22)';

const p = adaniProducts[0];
---

<Layout
  title="Adani Solar DCR 545Wp Panel India | Ready Stock | Techedge"
  description="Adani Solar DCR 545Wp solar panel — DCR compliant, MNRE approved, ready stock. High-efficiency, subsidy-eligible modules for government and DISCOM net-metered projects. Supply by Techedge Bengaluru."
  keywords="Adani solar panel India, Adani DCR module, DCR compliant solar panel, MNRE approved panel, 545Wp solar panel, PM Surya Ghar DCR panel"
>

  <!-- Hero -->
  <section class="pt-32 pb-16 px-4 border-b border-muted/10" style={`background:linear-gradient(135deg,#0a0a12 60%,${colorLight})`}>
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-6">
        <a href="/products/" class="text-muted text-sm hover:text-white">Products</a>
        <span class="text-muted/40">›</span>
        <span style={`color:${colorAccent}`} class="text-sm font-semibold">Adani Solar</span>
      </div>
      <div class="flex flex-wrap items-start gap-4 mb-4">
        <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full border" style={`color:${colorAccent};border-color:${colorBorder};background:${colorLight}`}>DCR Compliant</span>
        <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full border" style={`color:${colorAccent};border-color:${colorBorder};background:${colorLight}`}>MNRE Approved</span>
        <span class="text-xs font-bold uppercase tracking-widest px-2 py-1 rounded-full border" style={`color:${colorAccent};border-color:${colorBorder};background:${colorLight}`}>Ready Stock</span>
      </div>
      <h1 class="font-anton text-5xl md:text-7xl uppercase text-white leading-none mb-4">Adani Solar</h1>
      <p class="text-muted text-lg max-w-2xl mb-8">
        DCR 545Wp solar modules — India's most trusted solar brand. High power output, government-approved
        DCR compliance, and Adani's global quality assurance. In ready stock for immediate EPC supply.
      </p>
      <div class="flex flex-wrap gap-3">
        {[
          [`${p.powerWp}Wp`, 'Power Output'],
          ['DCR', 'Domestic Content'],
          ['MNRE', 'Approved'],
          ['Ready', 'Stock Available'],
        ].map(([v, l]) => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-xl px-5 py-3">
            <p class="text-xl font-grotesk font-bold text-white">{v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why DCR matters -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div>
        <h2 class="font-anton text-3xl uppercase text-foreground mb-6">Why DCR Compliance Matters</h2>
        <p class="text-muted text-sm leading-relaxed mb-4">
          DCR (Domestic Content Requirement) modules are manufactured in India using domestically produced solar cells,
          not just assembled here. Government schemes such as PM Surya Ghar, CPSU tenders, and several state and
          DISCOM subsidy programs mandate DCR modules for subsidy eligibility.
        </p>
        <p class="text-muted text-sm leading-relaxed">
          Adani Solar's {p.powerWp}Wp DCR module is MNRE approved and currently in ready stock — meaning no waiting on
          import lead times for subsidy-linked or government-tender projects.
        </p>
      </div>
      <div>
        <h2 class="font-anton text-3xl uppercase text-foreground mb-6">Key Features</h2>
        <ul class="space-y-3">
          {p.features.map(f => (
            <li class="flex items-start gap-3 text-sm text-muted">
              <span class="mt-0.5 shrink-0 font-bold" style={`color:${colorAccent}`}>✓</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Ideal For -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-8">Ideal For</h2>
      <div class="flex flex-wrap gap-3">
        {p.useCases.map(uc => (
          <span class="px-4 py-2 rounded-full border text-sm text-muted" style={`border-color:${colorBorder};background:${colorLight}`}>{uc}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-8">Certifications & Compliance</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {[
          ['DCR Compliant', 'Manufactured in India — eligible for DCR-mandated government and subsidy projects'],
          ['MNRE Approved', 'Meets Ministry of New and Renewable Energy standards'],
          ['Adani Quality Assurance', 'Backed by Adani\'s global manufacturing standards and performance warranty'],
        ].map(([cert, desc]) => (
          <div class="rounded-xl border p-4" style={`background:${colorLight};border-color:${colorBorder}`}>
            <p class="font-bold text-foreground text-sm mb-1">{cert}</p>
            <p class="text-muted text-xs">{desc}</p>
          </div>
        ))}
      </div>
      <p class="text-muted text-xs mt-6">
        Full electrical datasheet (Voc, Isc, Vmp, Imp, efficiency, warranty terms) available on request — contact Techedge for the current Adani Solar specification sheet and pricing.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-anton text-3xl uppercase text-foreground mb-4">Enquire About Adani Solar DCR Panels</h2>
      <p class="text-muted mb-8">Ready stock, per-Wp pricing, and EPC supply across Bengaluru and Karnataka.</p>
      <a href="/contact" class="inline-block font-anton text-lg uppercase px-8 py-4 rounded-xl border border-muted/30 hover:bg-muted-foreground/10 transition-colors text-foreground">
        Get a Quote →
      </a>
    </div>
  </section>

</Layout>
