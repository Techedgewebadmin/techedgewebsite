---
import Layout from "@/layouts/Layout.astro";
import { deyeProducts } from "@/data/deye-products";
import { allTechedgeProducts } from "@/data/techedge-products";
import { goldiProducts } from "@/data/goldi-products";
---

<Layout
  title="Solar Products — Deye, Goldi Solar, Techedge & Nunam | Techedge India"
  description="Solar products from Techedge India — Deye inverters & batteries, Goldi Solar TOPCon modules, Techedge solar kits for NGOs, and Nunam upcycled batteries. Authorised dealer, Bengaluru."
  keywords="Deye solar inverter India, Goldi Solar panel India, Techedge solar kit, Nunam battery India, solar products Bengaluru"
>

  <!-- Hero -->
  <section class="bg-background-foreground pt-32 pb-16 px-4 border-b border-muted/10">
    <div class="max-w-7xl mx-auto">
      <span class="text-secondary text-xs font-bold uppercase tracking-widest mb-4 block">Our Products</span>
      <h1 class="font-anton text-5xl md:text-7xl uppercase text-foreground leading-none mb-4">
        Solar Products
      </h1>
      <p class="text-muted text-lg max-w-2xl mb-8">
        Four trusted brands. One source. Deye inverters and batteries, Goldi Solar TOPCon panels,
        Techedge solar kits for NGOs and CSR, and Nunam upcycled LiFePO₄ batteries.
      </p>
      <div class="flex flex-wrap gap-4">
        {[
          { v: String(deyeProducts.length), l: 'Deye Products' },
          { v: String(goldiProducts.length), l: 'Goldi Modules' },
          { v: String(allTechedgeProducts.length), l: 'Techedge Kits' },
          { v: 'Nunam', l: 'Upcycled Batteries' },
        ].map(s => (
          <div class="bg-muted-foreground/5 border border-muted/20 rounded-xl px-5 py-3">
            <p class="text-2xl font-grotesk font-bold text-foreground">{s.v}</p>
            <p class="text-xs text-muted uppercase font-semibold">{s.l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Brand cards -->
  <section class="py-20 px-4">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">

      <!-- Deye -->
      <a href="/products/deye/" class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border-2 border-muted/20 hover:border-secondary/50 rounded-2xl p-8 flex flex-col transition-all duration-200">
        <div class="w-14 h-14 rounded-2xl bg-secondary/10 border border-secondary/20 flex items-center justify-center text-3xl mb-5">⚡</div>
        <div class="mb-2 flex flex-wrap items-center gap-2">
          <h2 class="font-anton text-2xl uppercase text-foreground group-hover:text-secondary transition-colors">Deye</h2>
          <span class="text-[10px] font-bold uppercase tracking-widest text-secondary bg-secondary/10 px-2 py-0.5 rounded-full">Authorised Dealer</span>
        </div>
        <p class="text-muted text-sm leading-relaxed mb-5">
          Commercial-grade solar inverters and LiFePO₄ batteries. On-grid, hybrid, micro and C&I ESS — 1.5 kW to 2.5 MW.
        </p>
        <div class="grid grid-cols-2 gap-2 mb-5 text-xs">
          {[
            ['⚡', 'On-Grid', '1.5–136 kW'],
            ['🔋', 'Hybrid', '3–125 kW'],
            ['🔲', 'Micro', '300–2200 W'],
            ['🏭', 'ESS', '5 kWh–2.5 MWh'],
          ].map(([icon, label, val]) => (
            <div class="bg-muted-foreground/10 rounded-xl px-3 py-2">
              <p class="font-bold text-foreground">{icon} {label}</p>
              <p class="text-muted">{val}</p>
            </div>
          ))}
        </div>
        <div class="flex-1" />
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-muted/10">
          <span class="text-muted text-xs">{deyeProducts.length} products</span>
          <span class="text-secondary font-bold text-sm group-hover:translate-x-1 transition-transform">View all →</span>
        </div>
      </a>

      <!-- Goldi Solar -->
      <a href="/products/goldi/" class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border-2 border-muted/20 hover:border-yellow-500/50 rounded-2xl p-8 flex flex-col transition-all duration-200">
        <div class="w-14 h-14 rounded-2xl bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-3xl mb-5">☀️</div>
        <div class="mb-2 flex flex-wrap items-center gap-2">
          <h2 class="font-anton text-2xl uppercase text-foreground group-hover:text-yellow-400 transition-colors">Goldi Solar</h2>
          <span class="text-[10px] font-bold uppercase tracking-widest text-yellow-400 bg-yellow-500/10 px-2 py-0.5 rounded-full border border-yellow-500/20">Authorised Dealer</span>
        </div>
        <p class="text-muted text-sm leading-relaxed mb-5">
          N-type TOPCon bifacial monocrystalline modules — 600–620 Wp, up to 22.95% efficiency, 30-year warranty. Made in India.
        </p>
        <div class="grid grid-cols-2 gap-2 mb-5 text-xs">
          {[
            ['☀️', 'HELOC PLUS', 'TOPCon N-type'],
            ['🔄', 'Bifacial', '80±5%'],
            ['📈', 'Efficiency', 'Up to 22.95%'],
            ['🛡️', 'Warranty', '30 years'],
          ].map(([icon, label, val]) => (
            <div class="bg-muted-foreground/10 rounded-xl px-3 py-2">
              <p class="font-bold text-foreground">{icon} {label}</p>
              <p class="text-muted">{val}</p>
            </div>
          ))}
        </div>
        <div class="flex-1" />
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-muted/10">
          <span class="text-muted text-xs">{goldiProducts.length} variants · EPC supply</span>
          <span class="text-yellow-400 font-bold text-sm group-hover:translate-x-1 transition-transform">View all →</span>
        </div>
      </a>

      <!-- Techedge -->
      <a href="/products/techedge/" class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border-2 border-muted/20 hover:border-green-500/50 rounded-2xl p-8 flex flex-col transition-all duration-200">
        <div class="w-14 h-14 rounded-2xl bg-green-500/10 border border-green-500/20 flex items-center justify-center text-3xl mb-5">🌿</div>
        <div class="mb-2 flex flex-wrap items-center gap-2">
          <h2 class="font-anton text-2xl uppercase text-foreground group-hover:text-green-400 transition-colors">Techedge</h2>
          <span class="text-[10px] font-bold uppercase tracking-widest text-green-400 bg-green-500/10 px-2 py-0.5 rounded-full border border-green-500/20">Our Brand</span>
        </div>
        <p class="text-muted text-sm leading-relaxed mb-5">
          Solar lanterns and home light kits for rural electrification, NGO distribution and CSR programs. MOQ 25 units.
        </p>
        <div class="grid grid-cols-2 gap-2 mb-5 text-xs">
          {[
            ['🔦', 'Lanterns', '2–6 hr backup'],
            ['🏠', 'Home Kits', '3–13 hr backup'],
            ['💡', 'Max Load', '4 × 5W LED'],
            ['📦', 'MOQ', '25 units'],
          ].map(([icon, label, val]) => (
            <div class="bg-muted-foreground/10 rounded-xl px-3 py-2">
              <p class="font-bold text-foreground">{icon} {label}</p>
              <p class="text-muted">{val}</p>
            </div>
          ))}
        </div>
        <div class="flex-1" />
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-muted/10">
          <span class="text-muted text-xs">{allTechedgeProducts.length} products</span>
          <span class="text-green-400 font-bold text-sm group-hover:translate-x-1 transition-transform">View all →</span>
        </div>
      </a>

      <!-- Nunam -->
      <a href="/products/nunam/" class="group bg-muted-foreground/5 hover:bg-muted-foreground/10 border-2 border-muted/20 hover:border-orange-500/50 rounded-2xl p-8 flex flex-col transition-all duration-200">
        <div class="w-14 h-14 rounded-2xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-3xl mb-5">♻️</div>
        <div class="mb-2 flex flex-wrap items-center gap-2">
          <h2 class="font-anton text-2xl uppercase text-foreground group-hover:text-orange-400 transition-colors">Nunam</h2>
          <span class="text-[10px] font-bold uppercase tracking-widest text-orange-400 bg-orange-500/10 px-2 py-0.5 rounded-full border border-orange-500/20">Supply Partner</span>
        </div>
        <p class="text-muted text-sm leading-relaxed mb-5">
          Upcycled LiFePO₄ battery modules from EV batteries — up to 30% cheaper than new lithium. Available in India through Techedge.
        </p>
        <div class="grid grid-cols-2 gap-2 mb-5 text-xs">
          {[
            ['🔋', 'NESS Series 5', '5 kWh / 48V'],
            ['🔄', 'Cycle Life', '2,000+'],
            ['📈', 'Scalable', 'Up to 50 kWh'],
            ['🛡️', 'Warranty', '5 years'],
          ].map(([icon, label, val]) => (
            <div class="bg-muted-foreground/10 rounded-xl px-3 py-2">
              <p class="font-bold text-foreground">{icon} {label}</p>
              <p class="text-muted">{val}</p>
            </div>
          ))}
        </div>
        <div class="flex-1" />
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-muted/10">
          <span class="text-muted text-xs">Enquire for India pricing</span>
          <span class="text-orange-400 font-bold text-sm group-hover:translate-x-1 transition-transform">Learn more →</span>
        </div>
      </a>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 bg-secondary/5 border-t border-muted/10">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-anton text-3xl md:text-4xl uppercase text-foreground mb-4">Not Sure Which Product?</h2>
      <p class="text-muted mb-8">Our team recommends the right product for your requirement — residential, commercial, NGO or CSR project.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-secondary text-black font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-secondary/90 transition-colors">
          Free Consultation
        </a>
        <a href="/solutions/" class="bg-muted-foreground/10 text-foreground font-anton text-lg uppercase px-8 py-4 rounded-xl hover:bg-muted-foreground/20 transition-colors border border-muted/30">
          View Solutions
        </a>
      </div>
    </div>
  </section>

</Layout>
