---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "@iconify-icon/react";
import { t } from "@/lib/utils";

---

<Layout
  title={t("meta.privacy.title")}
  description={t("meta.privacy.description")}
>
  <section class="pt-32 md:pt-40 pb-16 md:pb-24 px-4 min-h-screen">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-muted hover:text-secondary transition-colors mb-6"
        >
          <Icon client:only="react" icon="mdi:arrow-left" className="size-5" />
          <span class="font-grotesk">Back to Home</span>
        </a>
        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-anton uppercase leading-tight mb-6"
        >
          Privacy Policy
        </h1>
        <p class="text-muted font-sans text-lg">
          Last Updated: December 2026
        </p>
      </div>

      <!-- Content -->
      <div class="prose prose-lg max-w-none space-y-8">
        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">1. Introduction</h2>
          <p class="text-foreground/80 leading-relaxed mb-3">
            At Techedge, we are committed to protecting your personal data in compliance with applicable Indian laws, including the Digital Personal Data Protection Act, 2023 (DPDP Act) and the Information Technology Act, 2000.
          </p>
          <p class="text-foreground/80 leading-relaxed">
            By using our website or services, you consent to the collection and processing of your data as outlined below.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">2. Personal Data We Collect</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">We collect only the data required for service delivery and compliance:</p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80">
            <li><strong>Identity & Contact Data:</strong> Name, phone number, email address, location</li>
            <li><strong>Project & Technical Data:</strong> Site details, rooftop specifications, electrical infrastructure</li>
            <li><strong>Utility Data (DISCOM):</strong> Electricity bills, RR/Account number, tariff category, sanctioned load, and consumption history</li>
            <li><strong>Financial Data:</strong> Billing details and payment information (processed via secure third-party providers)</li>
            <li><strong>Communication Data:</strong> Emails, calls, WhatsApp messages, and enquiry forms</li>
            <li><strong>Technical Data:</strong> IP address, browser type, device details, and website usage</li>
          </ul>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">3. Purpose of Processing</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">Your data is used for:</p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80">
            <li>Solar system design, feasibility, and proposal preparation</li>
            <li>Site survey and engineering assessment</li>
            <li>Processing DISCOM approvals and net metering applications</li>
            <li>Project execution and after-sales service</li>
            <li>Payment processing and documentation</li>
            <li>Customer communication and updates</li>
            <li>Legal and regulatory compliance</li>
          </ul>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">4. Consent and Lawful Processing</h2>
          <p class="text-foreground/80 leading-relaxed mb-3">
            By sharing your details, including electricity (DISCOM) bill information, you provide consent for its use strictly for solar project evaluation, approvals, and service delivery.
          </p>
          <p class="text-foreground/80 leading-relaxed">
            You may withdraw consent at any time, subject to contractual and legal obligations.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">5. Data Sharing and Disclosure</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">We do not sell your data. Information may be shared only with:</p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80 mb-4">
            <li><strong>Authorized EPC teams and vendors</strong> – for project execution</li>
            <li><strong>DISCOM / Government authorities</strong> – for approvals and compliance</li>
            <li><strong>Payment service providers</strong> – for secure transactions</li>
            <li><strong>Legal authorities</strong> – where required by law</li>
          </ul>
          <p class="text-foreground/80 leading-relaxed">All parties are bound by confidentiality obligations.</p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">6. Data Security</h2>
          <p class="text-foreground/80 leading-relaxed">
            We implement appropriate safeguards to protect your data from unauthorized access, misuse, or disclosure. While we follow industry best practices, absolute security cannot be guaranteed.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">7. Data Retention</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">Data, including DISCOM and project-related information, is retained only for:</p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80 mb-4">
            <li>Project lifecycle and service requirements</li>
            <li>Regulatory and legal compliance</li>
          </ul>
          <p class="text-foreground/80 leading-relaxed">After this, data is securely deleted or anonymized.</p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">8. Your Rights</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">You have the right to:</p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80">
            <li>Access your data</li>
            <li>Request correction</li>
            <li>Request deletion (subject to legal requirements)</li>
            <li>Withdraw consent</li>
            <li>Raise grievances</li>
          </ul>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">9. Cookies Policy</h2>
          <p class="text-foreground/80 leading-relaxed">
            We use cookies to enhance user experience and analyze website usage. You may disable cookies through your browser settings.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">10. Children's Privacy</h2>
          <p class="text-foreground/80 leading-relaxed">
            Our services are intended for individuals above 18 years of age. We do not knowingly collect data from minors.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">11. Grievance Officer</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">For any data-related concerns:</p>
          <div class="mt-4 p-6 bg-muted rounded-xl">
            <p class="text-primary font-semibold">Grievance Officer – Techedge</p>
            <p class="text-primary/80">Email: sales@techedgeindia.co.in</p>
            <p class="text-primary/80">Phone: +91-9844097096</p>
          </div>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">12. Policy Updates</h2>
          <p class="text-foreground/80 leading-relaxed">
            This Privacy Policy may be updated from time to time. Changes will be reflected with the revised date.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">13. Contact Information</h2>
          <div class="mt-4 p-6 bg-muted rounded-xl">
            <p class="text-primary font-semibold">Techedge</p>
            <p class="text-primary/80">Email: sales@techedgeindia.co.in</p>
            <p class="text-primary/80">Phone: +91-9844097096</p>
            <p class="text-primary/80">Address: No. 10/11, Maragondanahalli Tavarekere, Bangalore – 562130, India</p>
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>
