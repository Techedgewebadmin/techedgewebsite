---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const posts = await getCollection("blog");

const mainPages = [
  { title: "Home", href: "/", desc: "India's trusted solar EPC company" },
  { title: "Solutions", href: "/solutions", desc: "On-grid, off-grid, hybrid, and cold storage solar systems" },
  { title: "Services", href: "/services", desc: "Design, installation, O&M, and consulting services" },
  { title: "Projects", href: "/projects", desc: "Real solar installations with verified savings data" },
  { title: "Blog", href: "/blog", desc: "Solar insights, guides, and case studies" },
  { title: "About Us", href: "/about", desc: "About Techedge Solar EPC" },
  { title: "Contact Us", href: "/contact", desc: "Free site survey and consultation" },
  { title: "ROI Calculator", href: "/roi", desc: "Calculate your solar return on investment" },
  { title: "Privacy Policy", href: "/privacy", desc: "" },
  { title: "Terms of Use", href: "/terms", desc: "" },
];

const solutions = [
  { title: "On-Grid Solar", href: "/solutions/on-grid-solar" },
  { title: "Off-Grid Solar", href: "/solutions/off-grid-solar" },
  { title: "Hybrid Solar", href: "/solutions/hybrid-solar" },
  { title: "Hybrid Solar Cold Storage", href: "/solutions/hybrid-solar-cold-storage" },
];
---

<Layout
  title="Techedge | Sitemap"
  description="Full sitemap of the Techedge solar website — all pages, projects, solutions, and blog articles."
  keywords="Techedge sitemap"
>
  <div class="h-24"></div>
  <div class="relative z-10 bg-background-foreground min-h-screen">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-24">

      <h1 class="font-anton text-4xl md:text-6xl uppercase text-foreground mb-2">Sitemap</h1>
      <p class="text-muted font-grotesk mb-16">All pages on techedgeindia.co.in</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        <!-- Main Pages -->
        <div>
          <h2 class="font-anton uppercase text-xl text-secondary mb-6 tracking-wide">Main Pages</h2>
          <ul class="space-y-4">
            {mainPages.map(page => (
              <li>
                <a href={page.href} class="group flex flex-col">
                  <span class="font-grotesk font-semibold text-foreground group-hover:text-secondary transition-colors">{page.title} →</span>
                  {page.desc && <span class="text-xs text-muted mt-0.5">{page.desc}</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="space-y-12">
          <!-- Solutions -->
          <div>
            <h2 class="font-anton uppercase text-xl text-secondary mb-6 tracking-wide">Solutions</h2>
            <ul class="space-y-4">
              {solutions.map(s => (
                <li>
                  <a href={s.href} class="font-grotesk font-semibold text-foreground hover:text-secondary transition-colors">{s.title} →</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Projects -->
          <div>
            <h2 class="font-anton uppercase text-xl text-secondary mb-6 tracking-wide">Projects</h2>
            <ul class="space-y-4">
              {projects.map(p => (
                <li>
                  <a href={`/projects/${p.id}`} class="group flex flex-col">
                    <span class="font-grotesk font-semibold text-foreground group-hover:text-secondary transition-colors">{p.data.title} →</span>
                    <span class="text-xs text-muted mt-0.5">{p.data.location} · {p.data.capacity}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Blog -->
          <div>
            <h2 class="font-anton uppercase text-xl text-secondary mb-6 tracking-wide">Blog</h2>
            <ul class="space-y-4">
              {posts.sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).map(post => (
                <li>
                  <a href={`/blog/${post.id}`} class="group flex flex-col">
                    <span class="font-grotesk font-semibold text-foreground group-hover:text-secondary transition-colors">{post.data.title} →</span>
                    <span class="text-xs text-muted mt-0.5">{post.data.category}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>
