---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import "@/styles/project-page.css";

export const prerender = true;

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, category, image, author, tags } = post.data;

const formattedDate = new Date(date).toLocaleDateString("en-IN", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={`${title} | Techedge Blog`} description={description} keywords={tags?.join(", ")}>

  <!-- Hero image -->
  <section class="fixed top-0 left-0 w-full h-dvh overflow-hidden z-0">
    <Image
      src={image}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover pointer-events-none"
      loading="eager"
      width={1600}
      height={900}
    />
    <div class="absolute inset-0 bg-black opacity-60 pointer-events-none"></div>
    <div class="relative z-10 h-full flex items-baseline-last p-4 lg:p-12">
      <div class="max-w-3xl space-y-4 text-accent-foreground">
        <span data-hero-el class="font-anton text-base md:text-lg uppercase tracking-wide text-secondary">
          {category}
        </span>
        <h1 data-hero-el class="text-3xl lg:text-5xl xl:text-7xl font-anton uppercase leading-none">
          {title}
        </h1>
        <p data-hero-el class="text-sm lg:text-base font-mono text-muted-foreground uppercase tracking-widest">
          {formattedDate} &nbsp;·&nbsp; {author}
        </p>
      </div>
    </div>
  </section>
  <div class="h-dvh"></div>

  <!-- Content -->
  <div class="relative z-10 bg-background-foreground">
    <div class="max-w-4xl mx-auto px-4 py-16 md:py-24">

      <!-- Back link -->
      <a href="/blog" class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider text-secondary hover:opacity-80 transition-opacity mb-12">
        ← Back to Blog
      </a>

      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {tags.map((tag) => (
            <span class="text-xs font-bold uppercase tracking-widest bg-accent text-secondary-foreground px-3 py-1 rounded-full border border-secondary/20">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Article body -->
      <div class="project-page">
        <article>
          <Content />
        </article>
      </div>

    </div>

  </div>

</Layout>
