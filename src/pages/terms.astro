---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "@iconify-icon/react";
import { t } from "@/lib/utils";
---

<Layout
  title={t("meta.terms.title")}
  description={t("meta.terms.description")}
>
  <section class="pt-32 md:pt-40 pb-16 md:pb-24 px-4 min-h-screen">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-muted hover:text-secondary transition-colors mb-6"
        >
          <Icon client:only="react" icon="mdi:arrow-left" className="size-5" />
          <span class="font-grotesk">Back to Home</span>
        </a>
        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-anton uppercase leading-tight mb-6"
        >
          Terms of Service
        </h1>
        <p class="text-muted font-sans text-lg">
          Last Updated: December 2026
        </p>
      </div>

      <!-- Content -->
      <div class="prose prose-lg max-w-none space-y-8">
        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">1. Agreement to Terms</h2>
          <p class="text-foreground/80 leading-relaxed mb-3">
            By accessing and using services provided by Techedge, you agree to comply with and be bound by these Terms of Service, applicable Indian laws, and regulations.
          </p>
          <p class="text-foreground/80 leading-relaxed">
            If you do not agree with any part of these terms, you must not use our website or services.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">2. Use of Website</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">
            All content, materials, and information available on Techedge's website are provided for general informational purposes only.
          </p>
          <p class="text-foreground/80 leading-relaxed mb-4">You agree not to:</p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80 mb-4">
            <li>Copy, reproduce, or modify any content without prior written consent</li>
            <li>Use the website for any unlawful or unauthorized purpose</li>
            <li>Attempt to gain unauthorized access to any part of the website or systems</li>
            <li>Reverse engineer or misuse any software or technical components</li>
          </ul>
          <p class="text-foreground/80 leading-relaxed">All intellectual property rights remain with Techedge.</p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">3. Solar Installation Services</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">
            Our solar EPC (Engineering, Procurement, and Construction) services are subject to the following:
          </p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80">
            <li>Final system design and execution are subject to site survey and technical feasibility</li>
            <li>Pricing may vary based on site conditions, electrical infrastructure, and material costs</li>
            <li>Project timelines are indicative and may change due to weather conditions, government approvals, DISCOM processes, or force majeure events</li>
            <li>Net metering approvals are subject to local DISCOM policies and regulations</li>
            <li>Detailed scope, deliverables, and timelines will be clearly defined in the final agreement</li>
          </ul>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">4. Payment Terms</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">
            Payment terms will be specified in the project agreement. Typically:
          </p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80 mb-4">
            <li>Advance payment is required at the time of order confirmation</li>
            <li>Milestone-based payments may be applicable during project execution</li>
            <li>Final payment is due upon commissioning or handover</li>
          </ul>
          <p class="text-foreground/80 leading-relaxed">
            Accepted payment methods include bank transfer, cheque, and approved financing options.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">5. Warranties and Performance</h2>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80">
            <li>Solar modules, inverters, and other components carry manufacturer warranties as per industry standards</li>
            <li>Installation workmanship warranty will be provided by Techedge as defined in the agreement</li>
            <li>Performance estimates are indicative and may vary based on weather, usage, and site conditions</li>
            <li>Any government subsidy benefits are subject to eligibility and policy at the time of application</li>
          </ul>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">6. Limitation of Liability</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">Techedge shall not be liable for:</p>
          <ul class="list-disc pl-6 space-y-2 text-foreground/80 mb-4">
            <li>Indirect or consequential losses, including loss of revenue or business interruption</li>
            <li>Delays caused by third parties such as DISCOM, government bodies, or force majeure events</li>
            <li>Variations in solar generation due to environmental or operational factors</li>
          </ul>
          <p class="text-foreground/80 leading-relaxed">
            Liability, if any, shall be limited to the value defined in the executed agreement.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">7. Governing Law and Jurisdiction</h2>
          <p class="text-foreground/80 leading-relaxed mb-3">
            These Terms shall be governed by and interpreted in accordance with the laws of India.
          </p>
          <p class="text-foreground/80 leading-relaxed">
            All disputes shall be subject to the exclusive jurisdiction of the courts in Bengaluru, Karnataka.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">8. Changes to Terms</h2>
          <p class="text-foreground/80 leading-relaxed">
            Techedge reserves the right to update or modify these Terms of Service at any time without prior notice. Continued use of the website or services constitutes acceptance of the revised terms.
          </p>
        </section>

        <section>
          <h2 class="text-3xl font-anton uppercase mb-4">9. Contact Information</h2>
          <p class="text-foreground/80 leading-relaxed mb-4">
            For any queries regarding these Terms of Service, please contact:
          </p>
          <div class="mt-4 p-6 bg-muted rounded-xl">
            <p class="text-primary font-semibold">Techedge</p>
            <p class="text-primary/80">Email: sales@techedgeindia.co.in</p>
            <p class="text-primary/80">Phone: +91-9844097096</p>
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>
