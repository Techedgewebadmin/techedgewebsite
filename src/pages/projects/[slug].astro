---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { render } from "astro:content";
import BreadCrumb from "@/components/common/BreadCrumb.astro";
import CtaSlug from "@/components/common/CtaSlug.astro";
import { t } from "@/lib/utils";

export const prerender = true;

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  category,
  location,
  capacity,
  date,
  image,
  description,
  stats,
  client,
  clientImage,
  additionalImages,
  logo,
  heroFit,
} = project.data;

// When additionalImages present, use a collage hero; otherwise single image
const hasCollage = additionalImages && additionalImages.length >= 2;
const collageOwner = hasCollage ? additionalImages![0] : null;
const collageInstall = hasCollage ? additionalImages![1] : null;
---

<Layout
  title={title}
  description={description}
  image={image.src}
>
  <!-- Hero: collage layout (owner + install shots) OR single full-bleed image -->
  {hasCollage ? (
    <section class="fixed top-0 left-0 w-full h-dvh overflow-hidden z-0 bg-black">
      <!-- 3-panel collage grid: panels image (left 60%) | owner photo top-right | aerial bottom-right -->
      <div class="absolute inset-0 grid grid-cols-5 grid-rows-2 gap-0.5">
        <!-- Main panels image — spans all 2 rows on left -->
        <div class="col-span-3 row-span-2 relative overflow-hidden">
          <Image
            src={image}
            alt={title}
            class="w-full h-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-black/30" />
        </div>
        <!-- Owner photo — top right, with name badge -->
        <div class="col-span-2 row-span-1 relative overflow-hidden">
          <Image
            src={collageOwner!}
            alt={`${client} — Techedge solar client`}
            class="w-full h-full object-cover object-top"
            loading="eager"
          />
          <div class="absolute inset-0 bg-black/20" />
          {client && (
            <div class="absolute bottom-2 left-2 bg-black/70 backdrop-blur-sm text-white text-[10px] font-bold px-2 py-1 rounded-full border border-white/20">
              ⭐ {client}
            </div>
          )}
        </div>
        <!-- Aerial / install shot — bottom right -->
        <div class="col-span-2 row-span-1 relative overflow-hidden">
          <Image
            src={collageInstall!}
            alt="Solar installation — aerial view"
            class="w-full h-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-black/25" />
          <div class="absolute bottom-2 left-2 bg-[#8DC63F]/90 text-black text-[10px] font-bold px-2 py-1 rounded-full">
            📍 Bengaluru Install
          </div>
        </div>
      </div>

      <!-- Overlay gradient so text stays readable -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent pointer-events-none" />

      <!-- Hero text + info card -->
      <div class="relative z-10 h-full flex items-baseline-last justify-between p-4 lg:p-12">
        <div class="max-w-3xl space-y-4 text-white">
          <span data-hero-el class="font-anton text-base md:text-lg uppercase tracking-wide text-[#8DC63F]">
            {category}
          </span>
          <h1 data-hero-el class="text-4xl lg:text-6xl xl:text-8xl font-anton uppercase leading-none">
            {title}
          </h1>
          <p data-hero-el class="text-base lg:text-lg max-w-xl font-sans text-white/85">
            {description}
          </p>
        </div>
        <div class="hidden lg:flex w-fit relative h-full flex-col p-4 md:p-6 justify-end">
          <div data-hero-el class="bg-black/70 backdrop-blur-sm rounded-2xl p-6 space-y-3 min-w-[200px] border border-white/10">
            <div>
              <p class="text-[0.65rem] uppercase tracking-wider text-white/50 font-semibold">Location</p>
              <p class="text-sm font-bold text-white">{location}</p>
            </div>
            <div>
              <p class="text-[0.65rem] uppercase tracking-wider text-white/50 font-semibold">Capacity</p>
              <p class="text-sm font-bold text-white">{capacity}</p>
            </div>
            <div>
              <p class="text-[0.65rem] uppercase tracking-wider text-white/50 font-semibold">Completed</p>
              <p class="text-sm font-bold text-white">{date}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class={`fixed top-0 left-0 w-full h-dvh overflow-hidden z-0 ${heroFit === 'contain' ? 'bg-black' : ''}`}>
      <Image
        src={image}
        alt={title}
        class={`absolute inset-0 w-full h-full pointer-events-none ${heroFit === 'contain' ? 'object-contain' : 'object-cover'}`}
        loading="eager"
      />
      <div class="absolute inset-0 bg-black opacity-50 pointer-events-none"></div>
      <div class="relative z-10 h-full flex items-baseline-last justify-between p-4 lg:p-12">
        <div class="max-w-3xl space-y-4 text-accent-foreground">
          <span data-hero-el class="font-anton text-base md:text-lg uppercase tracking-wide text-secondary">
            {category}
          </span>
          <h1 data-hero-el class="text-4xl lg:text-6xl xl:text-8xl font-anton uppercase leading-none">
            {title}
          </h1>
          <p data-hero-el class="text-base lg:text-lg max-w-xl font-sans">
            {description}
          </p>
        </div>
        <div class="hidden lg:flex w-fit relative h-full flex-col p-4 md:p-6 justify-end">
          <div data-hero-el class="bg-background/80 backdrop-blur-sm rounded-2xl p-6 space-y-3 min-w-[200px]">
            <div>
              <p class="text-[0.65rem] uppercase tracking-wider text-muted-foreground font-semibold">Location</p>
              <p class="text-sm font-bold text-foreground">{location}</p>
            </div>
            <div>
              <p class="text-[0.65rem] uppercase tracking-wider text-muted-foreground font-semibold">Capacity</p>
              <p class="text-sm font-bold text-foreground">{capacity}</p>
            </div>
            <div>
              <p class="text-[0.65rem] uppercase tracking-wider text-muted-foreground font-semibold">Completed</p>
              <p class="text-sm font-bold text-foreground">{date}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}
  <div class="h-dvh"></div>

  <article class="relative z-10 bg-background-foreground pb-16 md:pb-24">
    <section class="bg-accent-foreground py-8 md:py-12 container mx-auto rounded-lg md:border-2 md:border-dashed md:border-muted">
      <div class="mx-auto px-4 max-w-7xl">
        <BreadCrumb title={title} />

      <!-- Two Column Layout -->
      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 max-w-7xl mx-auto px-4 mt-12 md:mt-20"
      >
        <!-- Left Sidebar - Stats (Sticky) -->
        <aside class="lg:col-span-4 space-y-6">
          <div class="lg:sticky lg:top-24 space-y-6">

            <!-- Owner photo card — collage projects only -->
            {clientImage && client && (
              <div class="bg-muted-foreground/10 border-dashed border-2 border-secondary-dark rounded-lg p-5 flex flex-col items-center text-center gap-3">
                <Image
                  src={clientImage}
                  alt={`${client} — Techedge solar client`}
                  width={100}
                  height={100}
                  class="w-24 h-24 rounded-full object-cover object-top border-4 border-secondary shadow-md"
                />
                <div>
                  <p class="font-bold text-foreground text-sm">{client}</p>
                  <p class="text-xs text-muted mt-0.5">{location}</p>
                  <div class="mt-2 flex items-center justify-center gap-1 text-[#8DC63F]">
                    {"★★★★★".split("").map(s => <span class="text-sm">{s}</span>)}
                  </div>
                  <p class="text-[11px] text-muted mt-1 italic">"Highly recommend Techedge!"</p>
                </div>
              </div>
            )}

            <!-- Project Stats -->
            <div
              class="bg-muted-foreground/10 border-dashed border-2 border-secondary-dark rounded-lg p-6"
            >
              <h3
                class="text-xl font-grotesk uppercase text-foreground mb-6 pb-3 border-b-2 border-dashed"
              >
                {t('project.slug.detail.title')}
              </h3>
              <div class="space-y-4">
                <div>
                  <p class="text-muted text-xs uppercase font-mono mb-1">
                    {t('project.slug.detail.location')}
                  </p>
                  <p class="text-foreground text-base font-grotesk">
                    {location}
                  </p>
                </div>
                <div>
                  <p class="text-muted text-xs uppercase font-mono mb-1">
                    {t('project.slug.detail.capacity')}
                  </p>
                  <p class="text-foreground text-base font-grotesk">
                    {capacity}
                  </p>
                </div>
                <div>
                  <p class="text-muted text-xs uppercase font-mono mb-1">
                    {t('project.slug.detail.completed')}
                  </p>
                  <p class="text-foreground text-base font-grotesk">
                    {date}
                  </p>
                </div>
                {
                  client && (
                    <div>
                      <p class="text-muted text-xs uppercase font-mono mb-1">
                        {t('project.slug.detail.client')}
                      </p>
                      <p class="text-foreground text-base font-grotesk">
                        {client}
                      </p>
                    </div>
                  )
                }
                {
                  logo && (
                    <div class="pt-2 border-t border-dashed border-muted">
                      <p class="text-muted text-xs uppercase font-mono mb-3">Subsidy By</p>
                      <img
                        src={logo}
                        alt="Partner logo"
                        class="h-12 w-auto object-contain"
                      />
                    </div>
                  )
                }
              </div>
            </div>

            <!-- Project Impact -->
            <div
              class="bg-muted-foreground/10 border-dashed border-2 border-muted rounded-lg p-6"
            >
              <h3
                class="text-xl font-grotesk uppercase text-foreground mb-6 pb-3 border-b-2 border-dashed"
              >
                {t('project.slug.impacts.title')}
              </h3>
              <div class="space-y-4">
                {
                  [
                    { label: t('project.slug.impacts.solarpanels'), value: stats.panelCount },
                    { label: t('project.slug.impacts.co2'), value: stats.co2Saved },
                    { label: t('project.slug.impacts.energy'), value: stats.energyGenerated },
                    { label: t('project.slug.impacts.payback'), value: stats.paybackPeriod },
                  ].map((stat) => (
                    <div class="flex flex-col items-start">
                      <p class="text-muted text-xs uppercase font-mono mb-1">
                        {stat.label}
                      </p>
                      <p class="text-xl font-grotesk text-foreground">
                        {stat.value}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </aside>

        <!-- Right Content - Article -->
        <main class="lg:col-span-8 pl-0 xl:pl-6">

          <!-- Photo collage strip (panels + aerial) below hero for collage projects -->
          {additionalImages && additionalImages.length >= 2 && (
            <div class="mb-8 grid grid-cols-2 gap-3 rounded-2xl overflow-hidden">
              <div class="relative aspect-video overflow-hidden rounded-xl">
                <Image
                  src={image}
                  alt="Solar panels — rooftop installation"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                  width={600}
                  height={340}
                />
                <div class="absolute bottom-2 left-2 bg-black/60 text-white text-[10px] font-semibold px-2 py-1 rounded-full">
                  🔆 Solar Panels — Bengaluru Roof
                </div>
              </div>
              <div class="relative aspect-video overflow-hidden rounded-xl">
                <Image
                  src={additionalImages[1]}
                  alt="Solar installation — overview"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                  width={600}
                  height={340}
                />
                <div class="absolute bottom-2 left-2 bg-[#8DC63F]/90 text-black text-[10px] font-semibold px-2 py-1 rounded-full">
                  📐 Full Installation View
                </div>
              </div>
            </div>
          )}

          <!-- Markdown Content -->
          <article class="project-page">
            <Content />
          </article>

          <!-- Client Testimonial Photo Card -->
          {clientImage && client && (
            <div class="mt-10 mb-6 bg-gradient-to-br from-secondary/10 to-transparent border-2 border-dashed border-secondary/40 rounded-2xl p-6 md:p-8 flex flex-col sm:flex-row items-center gap-6">
              <div class="shrink-0">
                <Image
                  src={clientImage}
                  alt={`${client} — happy Techedge solar client`}
                  width={120}
                  height={120}
                  class="w-28 h-28 rounded-full object-cover object-top border-4 border-secondary shadow-lg"
                />
              </div>
              <div>
                <div class="flex gap-0.5 text-[#8DC63F] mb-2 text-base">★★★★★</div>
                <p class="text-lg font-grotesk text-foreground italic leading-relaxed">
                  "Would definitely recommend TechEdge India to anyone thinking about going solar."
                </p>
                <p class="mt-3 text-sm font-bold text-secondary">{client}</p>
                <p class="text-xs text-muted">{location}</p>
              </div>
            </div>
          )}

          <!-- CTA Section -->
          <CtaSlug />
        </main>
      </div>
    </section>
  </article>
</Layout>
