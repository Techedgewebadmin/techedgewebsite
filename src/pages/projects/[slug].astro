---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { render } from "astro:content";
import BreadCrumb from "@/components/common/BreadCrumb.astro";
import CtaSlug from "@/components/common/CtaSlug.astro";
import { t } from "@/lib/utils";

export const prerender = true;

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  category,
  location,
  capacity,
  date,
  image,
  description,
  stats,
  client,
} = project.data;
---

<Layout
  title={title}
  description={description}
  image={image.src}
>
  <!-- Hero with project image background -->
  <section class="fixed top-0 left-0 w-full h-dvh overflow-hidden z-0">
    <Image
      src={image}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover pointer-events-none"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black opacity-50 pointer-events-none"></div>
    <div class="relative z-10 h-full flex items-baseline-last justify-between p-4 lg:p-12">
      <div class="max-w-3xl space-y-4 text-accent-foreground">
        <span data-hero-el class="font-anton text-base md:text-lg uppercase tracking-wide text-secondary">
          {category}
        </span>
        <h1 data-hero-el class="text-4xl lg:text-6xl xl:text-8xl font-anton uppercase leading-none">
          {title}
        </h1>
        <p data-hero-el class="text-base lg:text-lg max-w-xl font-sans">
          {description}
        </p>
      </div>
      <div class="hidden lg:flex w-fit relative h-full flex-col p-4 md:p-6 justify-end">
        <div data-hero-el class="bg-background/80 backdrop-blur-sm rounded-2xl p-6 space-y-3 min-w-[200px]">
          <div>
            <p class="text-[0.65rem] uppercase tracking-wider text-muted-foreground font-semibold">Location</p>
            <p class="text-sm font-bold text-foreground">{location}</p>
          </div>
          <div>
            <p class="text-[0.65rem] uppercase tracking-wider text-muted-foreground font-semibold">Capacity</p>
            <p class="text-sm font-bold text-foreground">{capacity}</p>
          </div>
          <div>
            <p class="text-[0.65rem] uppercase tracking-wider text-muted-foreground font-semibold">Completed</p>
            <p class="text-sm font-bold text-foreground">{date}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="h-dvh"></div>

  <article class="relative z-10 bg-background-foreground pb-16 md:pb-24">
    <section class="bg-accent-foreground py-8 md:py-12 container mx-auto rounded-lg md:border-2 md:border-dashed md:border-muted">
      <div class="mx-auto px-4 max-w-7xl">
        <BreadCrumb title={title} />

      <!-- Two Column Layout -->
      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 max-w-7xl mx-auto px-4 mt-12 md:mt-20"
      >
        <!-- Left Sidebar - Stats (Sticky) -->
        <aside class="lg:col-span-4 space-y-6">
          <div class="lg:sticky lg:top-24 space-y-6">
            <!-- Project Stats -->
            <div
              class="bg-muted-foreground/10 border-dashed border-2 border-secondary-dark rounded-lg p-6"
            >
              <h3
                class="text-xl font-grotesk uppercase text-foreground mb-6 pb-3 border-b-2 border-dashed"
              >
                {t('project.slug.detail.title')}
              </h3>
              <div class="space-y-4">
                <div>
                  <p class="text-muted text-xs uppercase font-mono mb-1">
                    {t('project.slug.detail.location')}
                  </p>
                  <p class="text-foreground text-base font-grotesk">
                    {location}
                  </p>
                </div>
                <div>
                  <p class="text-muted text-xs uppercase font-mono mb-1">
                    {t('project.slug.detail.capacity')}
                  </p>
                  <p class="text-foreground text-base font-grotesk">
                    {capacity}
                  </p>
                </div>
                <div>
                  <p class="text-muted text-xs uppercase font-mono mb-1">
                    {t('project.slug.detail.completed')}
                  </p>
                  <p class="text-foreground text-base font-grotesk">
                    {date}
                  </p>
                </div>
                {
                  client && (
                    <div>
                      <p class="text-muted text-xs uppercase font-mono mb-1">
                        {t('project.slug.detail.client')}
                      </p>
                      <p class="text-foreground text-base font-grotesk">
                        {client}
                      </p>
                    </div>
                  )
                }
              </div>
            </div>

            <!-- Project Impact -->
            <div
              class="bg-muted-foreground/10 border-dashed border-2 border-muted rounded-lg p-6"
            >
              <h3
                class="text-xl font-grotesk uppercase text-foreground mb-6 pb-3 border-b-2 border-dashed"
              >
                {t('project.slug.impacts.title')}
              </h3>
              <div class="space-y-4">
                {
                  [
                    { label: t('project.slug.impacts.solarpanels'), value: stats.panelCount },
                    { label: t('project.slug.impacts.co2'), value: stats.co2Saved },
                    { label: t('project.slug.impacts.energy'), value: stats.energyGenerated },
                    { label: t('project.slug.impacts.payback'), value: stats.paybackPeriod },
                  ].map((stat) => (
                    <div class="flex flex-col items-start">
                      <p class="text-muted text-xs uppercase font-mono mb-1">
                        {stat.label}
                      </p>
                      <p class="text-xl font-grotesk text-foreground">
                        {stat.value}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </aside>

        <!-- Right Content - Article -->
        <main class="lg:col-span-8 pl-0 xl:pl-6">
          <!-- Markdown Content -->
          <article class="project-page">
            <Content />
          </article>

          <!-- CTA Section -->
          <CtaSlug />
        </main>
      </div>
    </section>
  </article>
</Layout>
